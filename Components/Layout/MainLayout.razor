@inherits LayoutComponentBase
@inject NavigationManager Navigation

@if (Navigation.Uri.Contains("/login") || Navigation.Uri.EndsWith("/"))
{
    <div class="login-full-layout">
        @Body
    </div>
}
else
{
    <div class="page">
        <div class="sidebar">
            <NavMenu />
        </div>

        <main>
            <div class="top-row px-4">
                <a href="https://learn.microsoft.com/aspnet/core/" target="_blank">About</a>
            </div>

            <article class="content px-4">
                @Body
            </article>
        </main>
    </div>
}

<style>
    .login-full-layout {
        width: 100vw;
        height: 100vh;
        margin: 0;
        padding: 0;
        overflow: hidden;
    }
</style>