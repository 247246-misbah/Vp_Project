@inherits LayoutComponentBase

<div class="page" style="background-color: #121212; min-height: 100vh;">
    <div class="sidebar">
        <NavMenu />
    </div>

    <main>
        <div class="top-row px-4" style="background-color: #1a1a1a; border-bottom: 1px solid #2d2d2d; justify-content: flex-end;">
            <span class="text-muted small me-2">Session Identity:</span>
            <span class="badge bg-warning text-dark fw-bold">Admin Console</span>
        </div>

        <article class="content px-4">
            @Body
        </article>
    </main>
</div>

<div id="blazor-error-ui">
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <a class="dismiss">×</a>
</div>
