@inherits LayoutComponentBase
@inject NavigationManager Navigation

@{
    // Check karein ke user login page par hai ya nahi
    var isLoginPage = Navigation.Uri.Contains("/login") || Navigation.Uri.EndsWith("/");
}

<div class="page">
    @if (!isLoginPage)
    {
        <div class="sidebar">
            <NavMenu />
        </div>
    }

    <main class="@(isLoginPage ? "full-screen-login" : "")">
        @if (!isLoginPage)
        {
            <div class="top-row px-4">
                <a href="https://learn.microsoft.com/aspnet/core/" target="_blank">About</a>
            </div>
        }

        <article class="@(isLoginPage ? "" : "content px-4")">
            @Body
        </article>
    </main>
</div>

<style>
    /* Agar login page ho to saari default padding aur margins khatam karke center align karein */
    .full-screen-login {
        width: 100vw !important;
        height: 100vh !important;
        margin: 0 !important;
        padding: 0 !important;
        display: flex !important;
        align-items: center !important;
        justify-content: center !important;
    }
</style>