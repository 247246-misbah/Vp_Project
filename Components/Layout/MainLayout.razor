@inherits LayoutComponentBase
@inject NavigationManager Navigation

@{
    // Check karein ke user login page ya profile page par hai ya nahi
    var isLoginPage = Navigation.Uri.Contains("/login") || Navigation.Uri.EndsWith("/");
    var isProfilePage = Navigation.Uri.Contains("/profile");
    
    // Agar dono mein se koi bhi true ho, to layout elements hide karein
    var hideSidebarAndHeader = isLoginPage || isProfilePage;
}

<div class="page">
    @if (!hideSidebarAndHeader)
    {
        <div class="sidebar">
            <NavMenu />
        </div>
    }

    <main class="@(hideSidebarAndHeader ? "full-screen-layout" : "")">
        @if (!hideSidebarAndHeader)
        {
            <div class="top-row px-4">
                <a href="https://learn.microsoft.com/aspnet/core/" target="_blank">About</a>
            </div>
        }

        <article class="@(hideSidebarAndHeader ? "" : "content px-4")">
            @Body
        </article>
    </main>
</div>

<style>
    /* Login aur Profile pages ko saari default spacing khatam karke poori screen dega */
    .full-screen-layout {
        width: 100vw !important;
        height: 100vh !important;
        margin: 0 !important;
        padding: 0 !important;
        display: flex !important;
        flex-direction: column !important;
    }
</style>