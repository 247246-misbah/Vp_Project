    </aside>

    <main class="dashboard-metric-workspace pos-layout-split">
        
        <div class="catalog-selection-column">
            <div class="column-header">
                <h1 class="pos-main-title">Digital Counter Terminal</h1>
            </div>

            @if (!string.IsNullOrEmpty(SystemFeedback))
            {
                <div class="pos-alert-toast">@SystemFeedback</div>
            }

            <div class="catalog-cards-grid">
                @if (AvailableMenu != null && AvailableMenu.Count > 0)
                {
                    @foreach (var prod in AvailableMenu)
                    {
                        <div class="product-selection-card" @onclick="() => AddToCart(prod)">
                            <div class="card-icon-tag">
                                @if (prod.Category == "Coffee")
                                {
                                    <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" fill="#e67e22" class="bi bi-cup-hot-fill" viewBox="0 0 16 16">
                                      <path fill-rule="evenodd" d="M.5 6a.5.5 0 0 0-.488.608l1.652 7.434A2.5 2.5 0 0 0 4.104 16h5.792a2.5 2.5 0 0 0 2.44-1.958l.131-.59a3 3 0 0 0 1.3-5.854l.221-.99A.5.5 0 0 0 13.5 6zM13 12.5a2 2 0 0 1-.316-.025l.867-3.898A2.001 2.001 0 0 1 13 12.5M4.4.8a.5.5 0 0 1 .154.541A3.2 3.2 0 0 0 4 2.5c-.074.405-.024.734.09 1.136a.5.5 0 1 1-.954.308C3.004 3.497 2.922 2.992 3 2.402a4.2 4.2 0 0 1 .53-1.408A.5.5 0 0 1 4.4.8m3 0a.5.5 0 0 1 .154.541A3.2 3.2 0 0 0 7 2.5c-.074.405-.024.734.09 1.136a.5.5 0 1 1-.954.308C6.004 3.497 5.922 2.992 6 2.402a4.2 4.2 0 0 1 .53-1.408A.5.5 0 0 1 7.4.8m3 0a.5.5 0 0 1 .154.541A3.2 3.2 0 0 0 10 2.5c-.074.405-.024.734.09 1.136a.5.5 0 1 1-.954.308c-.13-.437-.212-.942-.134-1.532a4.2 4.2 0 0 1 .53-1.408A.5.5 0 0 1 10.4.8"/>
                                    </svg>
                                }
                                else if (prod.Category == "Tea")
                                {
                                    <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" fill="#e67e22" class="bi bi-cup-straw" viewBox="0 0 16 16">
                                      <path d="M13.902.334a.5.5 0 0 1 split-.28l1.013 2.573A.5.5 0 0 1 14.5 3H13v1h1a1 1 0 0 1 1 1v10a1 1 0 0 1-1 1H2a1 1 0 0 1-1-1V5a1 1 0 0 1 1-1h1V3H1.5a.5.5 0 0 1-.415-.78L2.1 1.054A.5.5 0 0 1 2.5 1h10a.5.5 0 0 1 .466.318l.936 2.376zM11.218 3 10.43 1H5.57L4.782 3zM2 5v10h12V5z"/>
                                    </svg>
                                }
                                else
                                {
                                    <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" fill="#e67e22" class="bi bi-cake2-fill" viewBox="0 0 16 16">
                                      <path d="m8 0-.46.307a.5.5 0 0 0-.134.543l.305.762-1.087-.435a.5.5 0 0 0-.58.15L5.331 2.31 4.708 1.066a.5.5 0 0 0-.715-.195L3.5 1.22 3.107.433a.5.5 0 0 0-.83-.12l-.648.81a.5.5 0 0 0-.015.548l.911 1.519H1a1 1 0 0 0-1 1v3a1 1 0 0 0 1 1h14a1 1 0 0 0 1-1V4a1 1 0 0 0-1-1h-1.53l.911-1.52a.5.5 0 0 0-.015-.547l-.648-.81a.5.5 0 0 0-.83.12l-.393.787-.493-.986a.5.5 0 0 0-.715-.195L9.669 2.31 8.956 1.33a.5.5 0 0 0-.58-.15L7.29 1.615l.304-.761A.5.5 0 0 0 7.46.307zM0 8.5v6A1.5 1.5 0 0 0 1.5 16h13a1.5 1.5 0 0 0 1.5-1.5v-6zM1.5 9h13a.5.5 0 0 1 .5.5v1a.5.5 0 0 1-.5.5h-13A.5.5 0 0 1 0 10.5v-1a.5.5 0 0 1 .5-.5m0 3h13a.5.5 0 0 1 .5.5v1a.5.5 0 0 1-.5.5h-13a.5.5 0 0 1-.5-.5v-1a.5.5 0 0 1 .5-.5"/>
                                    </svg>
                                }
                            </div>
                            <div class="card-details">
                                <h4 class="prod-title">@prod.ItemName</h4>
                                <span class="prod-badge">@prod.Category</span>
                                <div class="prod-price-tag">Rs. @prod.Price.ToString("N0")</div>
                            </div>
                        </div>
                    }
                }
                else
                {
                    <p style="color: #a0aec0; grid-column: span 3; text-align: center; padding: 40px;">No menu items available. Configure your menu list first!</p>
                }
            </div>
        </div>

        <div class="invoice-summary-column">
            <div class="invoice-paper-card">
                <div class="invoice-header">
                    <h3>ACTIVE BILLING INVOICE</h3>
                    <input type="text" placeholder="Customer Name" class="customer-name-input" @bind="CustomerName" />
                </div>

                <div class="invoice-items-flow">
                    @if (CurrentCart != null && CurrentCart.Count > 0)
                    {
                        @foreach (var cartItem in CurrentCart)
                        {
                            <div class="cart-row-node">
                                <div class="cart-meta">
                                    <span class="cart-item-name">@cartItem.ItemName</span>
                                    <span class="cart-item-sub">Rs. @cartItem.UnitPrice.ToString("N0") each</span>
                                </div>
                                <div class="cart-qty-controls">
                                    <button class="qty-btn" @onclick="() => UpdateQuantity(cartItem, -1)">-</button>
                                    <span class="qty-display">@cartItem.Quantity</span>
                                    <button class="qty-btn" @onclick="() => UpdateQuantity(cartItem, 1)">+</button>
                                </div>
                                <div class="cart-subtotal">
                                    Rs. @cartItem.Subtotal.ToString("N0")
                                </div>
                            </div>
                        }
                    }
                    else
                    {
                        <div class="empty-cart-state">
                            <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" fill="#cbd5e0" class="bi bi-cart3 cart-empty-glyph" viewBox="0 0 16 16">
                              <path d="M0 1.5A.5.5 0 0 1 .5 1H2a.5.5 0 0 1 .485.379L2.89 3H14.5a.5.5 0 0 1 .49.598l-1 5a.5.5 0 0 1-.465.401l-9.397.472L4.415 11H13a.5.5 0 0 1 0 1H4a.5.5 0 0 1-.491-.408L2.01 3.607 1.61 2H.5a.5.5 0 0 1-.5-.5M3.102 4l.84 4.479 9.144-.459L13.89 4zM5 12a2 2 0 1 0 0 4 2 2 0 0 0 0-4m7 0a2 2 0 1 0 0 4 2 2 0 0 0 0-4m-7 1a1 1 0 1 1 0 2 1 1 0 0 1 0-2m7 0a1 1 0 1 1 0 2 1 1 0 0 1 0-2"/>
                            </svg>
                            <p>Cart invoice is completely empty.<br/>Select menu products to prepare token.</p>
                        </div>
                    }
                </div>

                <div class="invoice-footer-calculation">
                    <div class="summary-line font-bold-grand">
                        <span>Grand Total:</span>
                        <span class="amber-total">Rs. @GrandTotal.ToString("N0")</span>
                    </div>

                    <button class="btn-checkout-finalize" disabled="@(CurrentCart.Count == 0)" @onclick="FinalizeOrderTransaction">
                        Confirm & Place Order
                    </button>
                </div>
            </div>
        </div>

    </main>
</div>

@code {
    private List<MenuProductModel> AvailableMenu = new();
    private List<CartItemModel> CurrentCart = new();
    
    private string CustomerName { get; set; } = string.Empty;
    private string SystemFeedback { get; set; } = string.Empty;
    private decimal GrandTotal => CurrentCart.Sum(x => x.Subtotal);
    
    private string connString = "Server=localhost;Database=cafe_management;Uid=root;Pwd=;";

    protected override async Task OnInitializedAsync()
    {
        await FetchCatalogFromDatabase();
    }

    private async Task FetchCatalogFromDatabase()
    {
        AvailableMenu.Clear();
        try
        {
            using MySqlConnection conn = new(connString);
            await conn.OpenAsync();
            string query = "SELECT id, item_name, category, price FROM menu ORDER BY item_name ASC;";
            using MySqlCommand cmd = new(query, conn);
            using var reader = await cmd.ExecuteReaderAsync();
            while (await reader.ReadAsync())
            {
                AvailableMenu.Add(new MenuProductModel
                {
                    Id = reader.GetInt32("id"),
                    ItemName = reader.GetString("item_name"),
                    Category = reader.GetString("category"),
                    Price = reader.GetDecimal("price")
                });
            }
        }
        catch (Exception ex)
        {
            SystemFeedback = $"Catalog Error: {ex.Message}";
        }
    }

    private void AddToCart(MenuProductModel prod)
    {
        SystemFeedback = string.Empty;
        var existing = CurrentCart.FirstOrDefault(x => x.MenuId == prod.Id);
        if (existing != null)
        {
            existing.Quantity++;
            existing.Subtotal = existing.Quantity * existing.UnitPrice;
        }
        else
        {
            CurrentCart.Add(new CartItemModel
            {
                MenuId = prod.Id,
                ItemName = prod.ItemName,
                Quantity = 1,
                UnitPrice = prod.Price,
                Subtotal = prod.Price
            });
        }
    }

    private void UpdateQuantity(CartItemModel item, int amount)
    {
        item.Quantity += amount;
        if (item.Quantity <= 0)
        {
            CurrentCart.Remove(item);
        }
        else
        {
            item.Subtotal = item.Quantity * item.UnitPrice;
        }
    }

    private async Task FinalizeOrderTransaction()
    {
        if (CurrentCart.Count == 0) return;

        string activeCust = string.IsNullOrWhiteSpace(CustomerName) ? "Walk-in Guest" : CustomerName;

        try
        {
            using MySqlConnection conn = new(connString);
            await conn.OpenAsync();
            
            string insertOrderSql = "INSERT INTO orders (customer_name, total_amount, status) VALUES (@Cust, @Total, 'Pending'); SELECT LAST_INSERT_ID();";
            int generatedOrderId = 0;
            
            using (MySqlCommand cmd = new(insertOrderSql, conn))
            {
                cmd.Parameters.AddWithValue("@Cust", activeCust);
                cmd.Parameters.AddWithValue("@Total", GrandTotal);
                generatedOrderId = Convert.ToInt32(await cmd.ExecuteScalarAsync());
            }

            foreach (var item in CurrentCart)
            {
                string insertItemSql = "INSERT INTO order_items (order_id, item_name, quantity, unit_price, subtotal) VALUES (@Oid, @Name, @Qty, @Price, @Sub);";
                using MySqlCommand itemCmd = new(insertItemSql, conn);
                itemCmd.Parameters.AddWithValue("@Oid", generatedOrderId);
                itemCmd.Parameters.AddWithValue("@Name", item.ItemName);
                itemCmd.Parameters.AddWithValue("@Qty", item.Quantity);
                itemCmd.Parameters.AddWithValue("@Price", item.UnitPrice);
                itemCmd.Parameters.AddWithValue("@Sub", item.Subtotal);
                await itemCmd.ExecuteNonQueryAsync();
            }

            SystemFeedback = $"Transaction Confirmed! Order Token #{generatedOrderId} placed in Queue.";
            
            CurrentCart.Clear();
            CustomerName = string.Empty;
        }
        catch (Exception ex)
        {
            SystemFeedback = $"Transaction Processing Fault: {ex.Message}";
        }
    }

    public class MenuProductModel
    {
        public int Id { get; set; }
        public string ItemName { get; set; } = string.Empty;
        public string Category { get; set; } = string.Empty;
        public decimal Price { get; set; }
    }

    public class CartItemModel
    {
        public int MenuId { get; set; }
        public string ItemName { get; set; } = string.Empty;
        public int Quantity { get; set; }
        public decimal UnitPrice { get; set; }
        public decimal Subtotal { get; set; }
    }
}

<style>
    /* Structure Alignment Foundations */
    .dashboard-viewport-container {
        width: 100vw; height: 100vh; display: flex;
        background-color: #160d08; color: #ffffff;
        font-family: 'Segoe UI', system-ui, sans-serif;
        margin: 0; padding: 0; overflow: hidden;
        position: fixed; top: 0; left: 0; z-index: 999;
    }

    .sidebar-brand-panel {
        width: 320px; height: 100%; background-color: #120a06;
        padding: 50px 35px; display: flex; flex-direction: column;
        border-right: 1px solid rgba(230, 126, 34, 0.12); box-sizing: border-box;
    }

    .brand-header-node { display: flex; align-items: center; gap: 14px; margin-bottom: 55px; }
    .brand-logo-text { font-size: 1.4rem; font-weight: 800; letter-spacing: 1.5px; margin: 0; color: #ffffff; }

    .navigation-matrix-list { list-style: none; padding: 0; margin: 0; flex-grow: 1; }
    .nav-matrix-item {
        display: flex; align-items: center; gap: 15px; padding: 14px 0;
        color: #a0aec0; font-size: 0.85rem; font-weight: 700;
        text-transform: uppercase; letter-spacing: 2px; cursor: pointer; transition: all 0.25s ease;
    }
    .nav-matrix-item:hover { color: #ffffff; transform: translateX(6px); }
    .nav-matrix-item.active-state-node { color: #e67e22 !important; }

    .dashboard-metric-workspace { flex-grow: 1; padding: 45px 50px; box-sizing: border-box; background-color: #1a110a; }
    
    /* POS Dual Layout Split */
    .pos-layout-split { display: grid; grid-template-columns: 1.4fr 1fr; gap: 40px; height: 100%; overflow: hidden; }
    .catalog-selection-column { display: flex; flex-direction: column; height: 100%; overflow-y: auto; padding-right: 10px; }
    
    .pos-main-title { font-size: 2.0rem; font-weight: 800; color: #ffffff; margin: 0 0 6px 0; }

    .pos-alert-toast {
        background-color: rgba(46, 204, 113, 0.15); border: 1px solid #2ecc71;
        color: #ffffff; padding: 12px; border-radius: 6px; font-weight: 600; font-size: 0.9rem; margin-bottom: 20px;
    }

    /* Product Grid Cards Configuration */
    .catalog-cards-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(180px, 1fr)); gap: 16px; }
    .product-selection-card {
        background: #120a06; border: 1px solid rgba(255,255,255,0.06); border-radius: 10px;
        padding: 20px; cursor: pointer; display: flex; flex-direction: column; gap: 12px;
        transition: transform 0.2s, border-color 0.2s, background 0.2s;
    }
    .product-selection-card:hover { transform: translateY(-4px); border-color: #e67e22; background: rgba(230,126,34,0.04); }
    
    .card-icon-tag { display: flex; align-items: center; height: 32px; }
    .prod-title { font-size: 1.05rem; font-weight: 700; color: #fff; margin: 0; }
    .prod-badge { font-size: 0.7rem; color: #a0aec0; text-transform: uppercase; letter-spacing: 1px; font-weight: 600; }
    .prod-price-tag { color: #e67e22; font-weight: 700; font-size: 1.1rem; margin-top: 4px; }

    /* Right Invoice Summary Sheet Structural Layout */
    .invoice-summary-column { height: 100%; display: flex; flex-direction: column; }
    .invoice-paper-card {
        background: #ffffff; border-radius: 12px; color: #333333; padding: 30px;
        box-shadow: 0 15px 40px rgba(0,0,0,0.4); height: 100%; display: flex; flex-direction: column; box-sizing: border-box;
    }

    .invoice-header { border-bottom: 2px dashed #e2e8f0; padding-bottom: 18px; margin-bottom: 20px; }
    .invoice-header h3 { font-size: 1.1rem; font-weight: 800; color: #1a110a; letter-spacing: 1px; margin: 0 0 12px 0; text-align: center; }
    
    .customer-name-input {
        width: 100%; padding: 10px 14px; border: 1px solid #cbd5e0; border-radius: 6px;
        font-size: 0.9rem; outline: none; background-color: #f7fafc; box-sizing: border-box;
    }
    .customer-name-input:focus { border-color: #e67e22; background-color: #fff; }

    .invoice-items-flow { flex-grow: 1; overflow-y: auto; display: flex; flex-direction: column; gap: 14px; padding-right: 5px; }
    
    .cart-row-node { display: grid; grid-template-columns: 1.5fr auto 1fr; gap: 15px; align-items: center; border-bottom: 1px solid #edf2f7; padding-bottom: 12px; }
    .cart-item-name { font-weight: 700; color: #1a110a; display: block; font-size: 0.95rem; }
    .cart-item-sub { font-size: 0.75rem; color: #718096; }

    .cart-qty-controls { display: flex; align-items: center; background: #f7fafc; border-radius: 20px; border: 1px solid #e2e8f0; padding: 2px; }
    .qty-btn { background: none; border: none; width: 26px; height: 26px; font-weight: bold; cursor: pointer; color: #4a5568; font-size: 0.9rem; }
    .qty-display { width: 24px; text-align: center; font-size: 0.85rem; font-weight: 700; color: #1a110a; }
    .cart-subtotal { text-align: right; font-weight: 700; color: #1a110a; font-size: 0.95rem; }

