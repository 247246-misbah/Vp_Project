@page "/menu"
@using Misbah_VisualProgramming_Project.Models
@inject NavigationManager NavManager

<div class="d-flex flex-column flex-md-row" style="background-color: #ffffff; min-height: 100vh; font-family: 'Playfair Display', Georgia, serif;">
    
    <div class="sidebar-wrapper p-4 d-flex flex-column align-items-center" style="background-color: #dfc5a6; width: 260px; min-width: 260px; border-right: 2px solid #321e14;">
        
        <div class="rounded-circle d-flex align-items-center justify-content-center mb-4 mt-2" style="width: 110px; height: 110px; border: 3px solid #321e14; background-color: transparent;">
            <div class="text-center">
                <span style="font-size: 2.2rem; display: block; line-height: 1; color: #321e14;">☕</span>
                <div style="width: 20px; height: 1.5px; background-color: #321e14; margin: 4px auto 0 auto;"></div>
            </div>
        </div>

        <div class="w-100 layout-horizontal-line"></div>

        <div class="w-100 d-flex flex-column text-center flex-grow-1 pt-2 gap-1">
            <a href="/menu" class="cafe-nav-anchor">Home</a>
            <a href="/menu" class="cafe-nav-anchor">About Us</a>
            <a href="/menu" class="cafe-nav-anchor">Blog</a>
            <a href="/menu" class="cafe-nav-anchor d-flex justify-content-center align-items-center gap-1">Pages <span style="font-size:0.5rem; color:#321e14; transform: scaleY(1.2);">▶</span></a>
            <a href="/menu" class="cafe-nav-anchor d-flex justify-content-center align-items-center gap-1">Shortcodes <span style="font-size:0.5rem; color:#321e14; transform: scaleY(1.2);">▶</span></a>
            <a href="/menu" class="cafe-nav-anchor active-highlight-node">Shop</a>
            <a href="/menu" class="cafe-nav-anchor">Contact</a>
        </div>

        <div class="w-100 layout-horizontal-line mb-3"></div>

        <div class="d-flex gap-4 justify-content-center mb-2" style="color: #321e14; font-size: 0.95rem; font-family: 'Segoe UI', Arial, sans-serif;">
            <span style="cursor: pointer; font-weight: bold;">f</span>
            <span style="cursor: pointer;">📸</span>
            <span style="cursor: pointer;">🐦</span>
            <span style="cursor: pointer; font-weight: bold;">in</span>
        </div>
    </div>

    <div class="flex-grow-1 bg-white pb-5">
        
        <div class="position-relative text-white d-flex align-items-center justify-content-center text-center" style="height: 350px; background: linear-gradient(rgba(0,0,0,0.4), rgba(0,0,0,0.4)), url('https://images.unsplash.com/photo-1495474472287-4d71bcdd2085?q=80&w=1200') center/cover no-repeat;">
            <div class="px-4">
                <h1 class="display-3 mb-2" style="font-weight: 500; letter-spacing: 0.5px;">Coffee Heaven</h1>
                <p class="mx-auto text-light px-2 opacity-85 style-subtext" style="max-width: 620px; font-size: 0.85rem; line-height: 1.6;">Lorem ipsum dolor sit amet, consectetur adipiscing elit, sed do eiusmod tempor incididunt ut labore et dolore magna aliqua atin script and its variants, and.</p>
                <button type="button" class="btn text-uppercase px-4 py-2 mt-2 rounded-0 standard-hero-btn">Shop Here</button>
            </div>
        </div>

        <div class="text-center my-5">
            <h2 class="fw-bold d-inline-block text-dark m-0" style="font-size: 2.1rem; color: #321e14 !important; font-style: normal; font-weight: 700;">
                Our Hot Products
            </h2>
            <div class="mx-auto mt-2" style="width: 35px; height: 1.5px; background-color: #321e14;"></div>
        </div>

        <div class="container px-4" style="max-width: 1100px;">
            <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4 justify-content-center">
                @foreach (var coffeeItem in sampleProducts)
                {
                    <div class="col">
                        <div class="card h-100 border-0 p-3 shadow-sm card-matte-dark" style="border-radius: 0px; background-color: #1a1512;">
                            
                            <div class="d-flex flex-column h-100 p-2 text-center text-white" style="border: 1px dashed rgba(223, 197, 166, 0.25);">
                                
                                <div class="mb-3" style="height: 220px; overflow: hidden; background-color: #261f1a;">
                                    <img src="@coffeeItem.DisplayPic" alt="@coffeeItem.Name" class="w-100 h-100" style="object-fit: cover; opacity: 0.95;" />
                                </div>
                                
                                <div class="d-flex flex-column justify-content-between flex-grow-1">
                                    <div>
                                        <h4 class="fw-normal mb-1" style="font-size: 1.35rem; color: #dfc5a6;">@coffeeItem.Name</h4>
                                        <p class="mb-3 text-muted px-1 style-subtext" style="font-size: 0.75rem; line-height: 1.4; min-height: 35px;">@coffeeItem.Description</p>
                                    </div>
                                    
                                    <div class="pt-2 border-top border-secondary border-opacity-25 mt-auto">
                                        <div class="d-flex justify-content-between align-items-center mb-2 px-1 style-subtext" style="font-size: 0.8rem;">
                                            <span class="text-muted">Stock: @coffeeItem.Stock</span>
                                            <span class="fw-bold fs-6" style="color: #dfc5a6;">Rs. @coffeeItem.Price.ToString("F2")</span>
                                        </div>
                                        <button type="button" class="btn w-100 py-2 text-uppercase fw-bold interactive-card-action" @onclick="() => TriggerGateRoute(coffeeItem.ProductId)">
                                            + Add Order
                                        </button>
                                    </div>
                                </div>

                            </div>

                        </div>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

<style>
    .layout-horizontal-line {
        border-top: 1.5px solid #321e14;
        margin: 0.8rem 0;
        width: 100%;
        opacity: 0.8;
    }

    .cafe-nav-anchor {
        color: #321e14;
        text-decoration: none;
        font-weight: 500;
        font-size: 0.95rem;
        display: block;
        width: 100%;
        padding: 5px 0;
        transition: opacity 0.15s ease;
    }

        .cafe-nav-anchor:hover {
            opacity: 0.65;
            color: #000000;
        }

    .active-highlight-node {
        color: #ffffff !important;
        font-weight: 700;
    }

    .style-subtext {
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif !important;
    }

    .standard-hero-btn {
        background-color: transparent;
        border: 1.5px solid white;
        color: white;
        font-size: 0.7rem;
        letter-spacing: 1px;
        font-family: 'Segoe UI', sans-serif;
        font-weight: bold;
        transition: all 0.2s ease;
    }

        .standard-hero-btn:hover {
            background-color: #ffffff;
            color: #000000;
        }

    .interactive-card-action {
        background-color: #dfc5a6;
        color: #321e14;
        border: none;
        border-radius: 0px;
        font-family: 'Segoe UI', sans-serif;
        font-size: 0.75rem;
        letter-spacing: 0.5px;
        transition: all 0.2s ease;
    }

        .interactive-card-action:hover {
            background-color: #ffffff;
            color: #000000;
        }

    .sidebar-wrapper {
        position: sticky;
        top: 0;
        height: 100vh;
        overflow-y: auto;
    }

    @@media(max-width: 768px) {
        .sidebar-wrapper {
            position: relative;
            height: auto;
            width: 100%;
            min-width: 100%;
        }
    }
</style>

@code {
    public static readonly List<Product> sampleProducts = new()
    {
        new Product { ProductId = 1, Name = "Black Coffee", Description = "Artisan slow-brewed light roasted single-origin espresso extraction.", Price = 380.00m, Category = "Classic", DisplayPic = "https://images.unsplash.com/photo-1514432324607-a09d9b4aefdd?q=80&w=500", Stock = 15 },
        new Product { ProductId = 2, Name = "Hot Coffee", Description = "Signature steaming house roast blended perfectly with velvet frothed milk base.", Price = 420.00m, Category = "Blends", DisplayPic = "https://images.unsplash.com/photo-1541167760496-1628856ab772?q=80&w=500", Stock = 12 },
        new Product { ProductId = 3, Name = "Dark Coffee", Description = "Bold double espresso shot topped with signature delicate latte cream art patterns.", Price = 450.00m, Category = "Espresso", DisplayPic = "https://images.unsplash.com/photo-1594911774802-8822a707cbb3?q=80&w=500", Stock = 8 },
        new Product { ProductId = 4, Name = "Ceremonial Matcha", Description = "Authentic stone-ground organic Japanese green tea whisked with milk.", Price = 480.00m, Category = "Matcha", DisplayPic = "https://images.unsplash.com/photo-1536256263959-770b48d82b0a?q=80&w=500", Stock = 10 },
        new Product { ProductId = 5, Name = "Strawberry Matcha", Description = "Layered beverage with real strawberry puree reduction, milk, and matcha.", Price = 540.00m, Category = "Matcha", DisplayPic = "https://images.unsplash.com/photo-1594756202469-9ff9799a2e4e?q=80&w=500", Stock = 7 },
        new Product { ProductId = 6, Name = "Red Velvet Cake Slice", Description = "Traditional vibrant red cocoa sponge cake layers paired with vanilla frosting.", Price = 450.00m, Category = "Cakes", DisplayPic = "https://images.unsplash.com/photo-1586788680434-30d324671ff6?q=80&w=500", Stock = 6 }
    };

    private void TriggerGateRoute(int id)
    {
        NavManager.NavigateTo($"/checkout?id={id}");
    }
}