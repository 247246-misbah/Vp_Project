@page "/menu"
@using Misbah_VisualProgramming_Project.Models
@inject NavigationManager NavManager

<div class="container-fluid py-4 px-4" style="background-color: #fdfbf7; min-height: 100vh;">
    <div class="row mb-5">
        <div class="col-12">
            <div class="card border-0 shadow-sm rounded-4 p-4 bg-white border-start border-5" style="border-color: #6f4e37 !important;">
                <div>
                    <h2 class="fw-bold text-dark mb-1" style="font-family: 'Playfair Display', serif;">Our Specialty Espresso Menu</h2>
                    <p class="text-muted mb-0">Select a handcrafted signature item to immediately stream into live processing and checkout.</p>
                </div>
            </div>
        </div>
    </div>

    <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
        @foreach (var product in sampleProducts)
        {
            <div class="col">
                <div class="card h-100 border-0 shadow-sm rounded-4 overflow-hidden bg-white specialty-card d-flex flex-column">
                    <div class="position-relative overflow-hidden" style="height: 200px; background-color: #f3eade;">
                        <img src="@product.DisplayPic" alt="@product.Name" class="w-100 h-100 object-fit-cover" />
                        <span class="position-absolute top-0 start-0 m-3 badge bg-dark bg-opacity-75 px-3 py-2 rounded-pill small fw-bold text-uppercase">
                            @product.Category
                        </span>
                    </div>
                    
                    <div class="card-body p-4 d-flex flex-column justify-content-between flex-grow-1">
                        <div>
                            <h4 class="card-title fw-bold text-dark mb-2" style="font-family: 'Playfair Display', serif;">@product.Name</h4>
                            <p class="card-text text-secondary mb-4 small" style="line-height: 1.6; min-height: 55px;">@product.Description</p>
                        </div>
                        
                        <div class="d-flex justify-content-between align-items-center pt-3 border-top border-light mt-auto">
                            <div>
                                <small class="text-muted d-block fw-bold tracking-wider" style="font-size: 0.7rem;">NET PRICE</small>
                                <span class="fs-5 fw-extrabold" style="color: #6f4e37;">Rs. @product.Price.ToString("F2")</span>
                            </div>
                            <button type="button" class="btn px-4 py-2 fw-bold rounded-pill text-dark btn-add" @onclick="() => DirectToInstantCheckout(product)">
                                + Add Order
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</div>

<style>
    .specialty-card {
        transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
    }
    .specialty-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 15px 35px rgba(111,78,55,0.12) !important;
    }
    .btn-add {
        border: 2px solid #6f4e37;
        background: transparent;
        transition: all 0.2s ease-in-out;
        font-size: 0.85rem;
    }
    .btn-add:hover {
        background-color: #6f4e37;
        color: white !important;
    }
    .object-fit-cover {
        object-fit: cover;
    }
</style>

