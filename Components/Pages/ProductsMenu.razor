@page "/menu"
@using Misbah_VisualProgramming_Project.Models
@inject NavigationManager NavManager

<div class="container-fluid py-4 px-4" style="background-color: #fdfbf7; min-height: 100vh;">
    <div class="row mb-5">
        <div class="col-12">
            <div class="card border-0 shadow-sm rounded-4 p-4 bg-white d-flex flex-row justify-content-between align-items-center flex-wrap border-start border-5" style="border-color: #6f4e37 !important;">
                <div>
                    <h2 class="fw-bold text-dark mb-1" style="font-family: 'Playfair Display', serif;">Our Specialty Espresso Menu</h2>
                    <p class="text-muted mb-0">Select handcrafted signature brews and treats to queue into live production channels.</p>
                </div>
                <div class="mt-3 mt-sm-0 bg-light px-4 py-3 rounded-4 d-flex align-items-center border">
                    <div class="me-3">
                        <span class="text-muted d-block small fw-bold">ACTIVE BASKET</span>
                        <span class="fw-extrabold text-dark">@SelectedItemsCount Selected Items</span>
                    </div>
                    @if (SelectedItemsCount > 0)
                    {
                        <button class="btn text-white px-4 fw-bold shadow-sm" style="background-color: #16a085; border: none;" @onclick="ProceedToCheckout">
                            Checkout Order →
                        </button>
                    }
                </div>
            </div>
        </div>
    </div>

    <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
        @foreach (var product in sampleProducts)
        {
            <div class="col">
                <div class="card h-100 border-0 shadow-sm rounded-4 overflow-hidden bg-white specialty-card">
                    <div class="position-relative text-center py-5" style="background: linear-gradient(135deg, #fdfbf7, #f3eade);">
                        <span style="font-size: 4.5rem;">@product.DisplayPic</span>
                        <span class="position-absolute top-0 start-0 m-3 badge bg-dark px-3 py-2 rounded-pill">@product.Category</span>
                    </div>
                    
                    <div class="card-body p-4 d-flex flex-column justify-content-between">
                        <div>
                            <h4 class="card-title fw-bold text-dark mb-2" style="font-family: 'Playfair Display', serif;">@product.Name</h4>
                            <p class="card-text text-secondary mb-4" style="font-size: 0.9rem; line-height: 1.6;">@product.Description</p>
                        </div>
                        
                        <div class="d-flex justify-content-between align-items-center pt-3 border-top border-light">
                            <div>
                                <small class="text-muted d-block fw-bold tracking-wider">NET PRICE</small>
                                <span class="fs-4 fw-extrabold" style="color: #6f4e37;">Rs. @product.Price.ToString("F2")</span>
                            </div>
                            <button class="btn px-4 fw-bold rounded-pill text-dark btn-add" @onclick="() => AddToBasket(product)">
                                + Add Order
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</div>

<style>
    .specialty-card {
        transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
    }

        .specialty-card:hover {
            transform: translateY(-6px);
            box-shadow: 0 12px 30px rgba(111,78,55,0.12) !important;
        }

    .btn-add {
        border: 2px solid #6f4e37;
        background: transparent;
        transition: all 0.2s;
    }

        .btn-add:hover {
            background-color: #6f4e37;
            color: white !important;
        }
</style>

