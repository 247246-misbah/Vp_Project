        new Product { ProductId = 10, Name = "Lotus Biscoff Cheesecake", Description = "Rich creamy New York style cheesecake on a crushed Biscoff crust, layered smoothly with melted speculoos cookie butter.", Price = 580.00m, Category = "Cakes", DisplayPic = "🍰" },
        new Product { ProductId = 11, Name = "Red Velvet Dream Slice", Description = "Traditional vibrant red cocoa sponge cake layers paired perfectly with signature tangy vanilla bean cream cheese frosting.", Price = 450.00m, Category = "Cakes", DisplayPic = "🍰" },

        // --- PASTA & SAVORIES ---
        new Product { ProductId = 12, Name = "Creamy Alfredo Fettuccine", Description = "Tender fettuccine pasta tossed in a rich parmesan and garlic butter cream sauce, topped with sliced grilled chicken breasts.", Price = 690.00m, Category = "Pasta", DisplayPic = "🍝" },
        new Product { ProductId = 13, Name = "Spicy Arrabiata Pasta", Description = "Al dente penne pasta coated evenly in a fiery slow-simmered tomato sauce infused with chili flakes, garlic, and fresh basil leaves.", Price = 620.00m, Category = "Pasta", DisplayPic = "🍝" },
        new Product { ProductId = 14, Name = "Four-Cheese Baked Lasagna", Description = "Layered sheet pasta stuffed with minced savory filling, marinara sauce, and loaded with melted mozzarella, ricotta, and cheddar.", Price = 750.00m, Category = "Pasta", DisplayPic = "🍲" }
    };

    private void AddToBasket(Product product)
    {
        SelectedItemsCount++;
        OrderTotal += product.Price;
    }

    private void ProceedToCheckout()
    {
        NavManager.NavigateTo($"/checkout?items={SelectedItemsCount}&total={OrderTotal}");
    }

    public class Product
    {
        public int ProductId { get; set; }
        public string Name { get; set; } = string.Empty;
        public string Description { get; set; } = string.Empty;
        public decimal Price { get; set; }
        public string Category { get; set; } = string.Empty;
        public string DisplayPic { get; set; } = string.Empty; // Property for icons/pics box alignment
    }
}