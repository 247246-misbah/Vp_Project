@page "/products-menu"
@inject Misbah_VisualProgramming_Project.Services.CafeService CafeService

<div class="menu-container p-4 min-vh-100 text-white" style="background-color: #0c0f14;">
    <div class="mb-4">
        <h2 class="fw-bold text-warning mb-1">☕ Espresso Menu Showcase</h2>
        <p class="text-muted small">Explore and purchase handcrafted retail blends matching your taste parameters.</p>
    </div>

    @if (products == null)
    {
        <div class="text-center my-5">
            <div class="spinner-border text-warning" role="status"></div>
            <p class="text-muted mt-2">Loading digital items...</p>
        </div>
    }
    else if (!products.Any())
    {
        <div class="alert alert-dark text-center py-5 shadow-sm border border-secondary border-opacity-10">
            <p class="text-muted mb-0">No items active in SQL database schema context.</p>
        </div>
    }
    else
    {
        <div class="row g-4">
            @foreach (var product in products)
            {
                <div class="col-12 col-md-6 col-lg-4 col-xl-3">
                    <div class="card h-100 border border-secondary border-opacity-10 shadow-sm transition-card" style="background: #171b22; border-radius: 16px; overflow: hidden;">
                        <div class="position-relative" style="height: 200px; width: 100%; background-color: #222;">
                            <img src="@product.ImageUrl" class="w-100 h-100 object-fit-cover" alt="@product.Name" />
                            <span class="position-absolute top-3 start-3 badge bg-dark bg-opacity-75 text-warning tracking-wider text-uppercase border border-warning border-opacity-20" style="font-size: 0.75rem; padding: 6px 12px; border-radius: 20px;">
                                @product.Category
                            </span>
                        </div>
                        <div class="card-body d-flex flex-column justify-content-between p-4">
                            <div>
                                <h5 class="card-title fw-bold text-white mb-2">@product.Name</h5>
                                <div class="d-flex justify-content-between align-items-center mb-3">
                                    <span class="fs-4 fw-bold text-warning font-monospace">Rs. @product.Price.ToString("F2")</span>
                                    <span class="small @(product.Stock > 0 ? "text-success" : "text-danger")">
                                        ● @(product.Stock > 0 ? $"{product.Stock} Available" : "Out of Stock")
                                    </span>
                                </div>
                            </div>
                            <button class="btn btn-warning w-100 fw-bold py-2" style="border-radius: 10px;" disabled="@(product.Stock <= 0)">
                                Add to Cart
                            </button>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

<style>
    .object-fit-cover { object-fit: cover !important; }
    .transition-card { transition: transform 0.2s ease, box-shadow 0.2s ease; }
    .transition-card:hover { transform: translateY(-5px); box-shadow: 0 10px 20px rgba(255, 193, 7, 0.1) !important; }
    .top-3 { top: 1rem !important; }
    .start-3 { start: 1rem !important; }
</style>

@code {
    private List<Misbah_VisualProgramming_Project.Models.Product>? products;

    protected override async Task OnInitializedAsync()
    {
        products = await CafeService.GetAllProductsAsync();
    }
}