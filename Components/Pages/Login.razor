@page "/login"
@layout Microsoft.AspNetCore.Components.LayoutComponentBase
@using Misbah_VisualProgramming_Project.Services
@using Misbah_VisualProgramming_Project.Data
@inject AuthService AuthService
@inject NavigationManager Navigation
@rendermode Microsoft.AspNetCore.Components.Web.RenderMode.InteractiveServer

<div class="login-outer-viewport">
    <div class="login-card-box">
        <div class="brand-header text-center">
            <div class="logo-circle shadow">
                <span class="logo-glyph">☕</span>
            </div>
            <h2 class="portal-title">Cafe Cove</h2>
            <p class="portal-subtitle">Management Portal</p>
            
            <div class="campus-tag">
                <span>Air University Kharian Campus</span>
            </div>
        </div>

        @if (!string.IsNullOrEmpty(errorMessage))
        {
            <div class="alert alert-danger shadow-sm" role="alert">
                ⚠️ @errorMessage
            </div>
        }

        <form @onsubmit="HandleLoginAsync" @onsubmit:preventDefault>
            <div class="mb-3">
                <label class="form-label text-secondary fw-semibold">Username or Email</label>
                <input type="text" class="form-control form-control-lg custom-input" @bind="usernameInput" placeholder="administrator" required />
            </div>

            <div class="mb-4">
                <label class="form-label text-secondary fw-semibold">Password</label>
                <input type="password" class="form-control form-control-lg custom-input" @bind="passwordInput" placeholder="••••••••" required />
            </div>

            <div class="d-flex justify-content-between align-items-center mb-4 small-text-row">
                <div class="form-check">
                    <input type="checkbox" class="form-check-input" id="remember" />
                    <label class="form-check-label text-muted" for="remember">Remember Me</label>
                </div>
                <a href="javascript:void(0)" class="forgot-pwd-link">Forgot Password?</a>
            </div>

            <button type="submit" class="btn btn-submit-action w-100 py-3 text-uppercase" disabled="@isProcessing">
                @if (isProcessing)
                {
                    <span class="spinner-border spinner-border-sm me-2"></span>
                    <span>Verifying Credentials...</span>
                }
                else
                {
                    <span>LOG IN 🚀</span>
                }
            </button>
        </form>

        <div class="portal-footer text-center mt-4">
            <p class="text-muted mb-1">Staff & Faculty Access Only.</p>
            <p class="text-muted">For student portals, <a href="javascript:void(0)" class="student-link fw-semibold">click here</a>.</p>
        </div>
    </div>
</div>

<style>
    /* Full screen absolute viewport configuration to hide background layouts */
    .login-outer-viewport {
        position: fixed;
        top: 0;
        left: 0;
        width: 100vw;
        height: 100vh;
        z-index: 99999;
        display: flex;
        align-items: center;
        justify-content: center;
        background: linear-gradient(135deg, #0f2027 0%, #203a43 50%, #2c5364 100%);
        padding: 20px;
        box-sizing: border-box;
    }

    .login-card-box {
        background: #ffffff;
        border-radius: 16px;
        box-shadow: 0 20px 40px rgba(0, 0, 0, 0.4);
        width: 100%;
        max-width: 440px;
        padding: 45px 40px;
    }

    .logo-circle {
        width: 70px;
        height: 70px;
        background: #1a365d;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 15px;
    }

    .logo-glyph { font-size: 32px; }
    .portal-title { color: #1a365d; font-weight: 700; margin-bottom: 2px; font-size: 1.8rem; }
    .portal-subtitle { color: #555; font-size: 1.05rem; margin-bottom: 15px; }
    
    .campus-tag {
        background: #e2e8f0;
        color: #2b6cb0;
        padding: 6px 18px;
        border-radius: 50px;
        font-size: 0.8rem;
        font-weight: 600;
        display: inline-block;
        margin-bottom: 30px;
        border: 1px solid #cbd5e0;
    }

    .custom-input {
        border-radius: 8px;
        border: 1px solid #ced4da;
        font-size: 1rem;
    }

    .custom-input:focus {
        border-color: #2b6cb0;
        box-shadow: 0 0 0 0.25rem rgba(43, 108, 176, 0.2);
    }

    .small-text-row { font-size: 0.88rem; }
    .forgot-pwd-link, .student-link { color: #2b6cb0; text-decoration: none; }
    .forgot-pwd-link:hover, .student-link:hover { text-decoration: underline; }

    .btn-submit-action {
        background: #1a365d;
        color: white;
        font-weight: 600;
        border-radius: 8px;
        border: none;
        letter-spacing: 0.5px;
        transition: all 0.2s ease-in-out;
    }

    .btn-submit-action:hover {
        background: #2b6cb0;
        color: white;
        transform: translateY(-1px);
        box-shadow: 0 5px 15px rgba(43, 108, 176, 0.3);
    }

    .alert { border-radius: 8px; font-size: 0.9rem; }
</style>

@code {
    private string usernameInput = string.Empty;
    private string passwordInput = string.Empty;
    private string errorMessage = string.Empty;
    private bool isProcessing = false;

    private async Task HandleLoginAsync()
    {
        errorMessage = string.Empty;
        isProcessing = true;

        try
        {
            var user = await AuthService.ValidateUserAsync(usernameInput, passwordInput);

            if (user != null)
            {
                // Force load direct trigger passes absolute clean state transition
                Navigation.NavigateTo("/dashboard", forceLoad: true);
            }
            else
            {
                errorMessage = "Access Denied: Invalid Username or Password.";
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Database Runtime Error: {ex.Message}";
        }
        finally
        {
            isProcessing = false;
        }
    }
}