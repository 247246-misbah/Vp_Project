@page "/login"
@using Misbah_VisualProgramming_Project.Services
@using Misbah_VisualProgramming_Project.Data
@inject AuthService AuthService
@inject NavigationManager Navigation
@rendermode Microsoft.AspNetCore.Components.Web.RenderMode.InteractiveServer

<div class="auth-viewport-wrapper">
    <div class="auth-card-panel shadow-lg animate-fade">
        
        <div class="brand-identity text-center">
            <div class="brand-avatar shadow">
                <span class="avatar-glyph">☕</span>
            </div>
            <h2 class="brand-title">Cafe Cove Management Portal</h2>
            
            <div class="institution-sub-badge">
                <span>Air University Kharian Campus</span>
            </div>
        </div>

        @if (!string.IsNullOrEmpty(feedbackMessage))
        {
            <div class="alert alert-danger border-0 rounded-3 text-center small mb-3 animate-shake" role="alert">
                ⚠️ @feedbackMessage
            </div>
        }

        <form @onsubmit="ExecuteAuthenticationAttempt" @onsubmit:preventDefault>
            
            <div class="mb-3">
                <label class="form-label text-muted fw-semibold small">Email or Username</label>
                <div class="input-group-custom">
                    <span class="input-icon-node">👤</span>
                    <input type="text" class="form-control-node" @bind="credentialInput" placeholder="administrator" required />
                </div>
            </div>

            <div class="mb-4">
                <label class="form-label text-muted fw-semibold small">Password</label>
                <div class="input-group-custom">
                    <span class="input-icon-node">🔒</span>
                    <input type="password" class="form-control-node" @bind="passwordInput" placeholder="••••••••••••" required />
                </div>
            </div>

            <div class="d-flex justify-content-between align-items-center mb-4 structural-action-row text-muted">
                <div class="form-check m-0">
                    <input type="checkbox" class="form-check-input" id="sessionLock" />
                    <label class="form-check-label check-label-text ms-1" for="sessionLock">Remember Me</label>
                </div>
                <a href="javascript:void(0)" class="utility-link">Forgot Password?</a>
            </div>

            <button type="submit" class="btn-submit-portal text-uppercase" disabled="@processingToggle">
                @if (processingToggle)
                {
                    <span class="spinner-border spinner-border-sm me-2" role="status"></span>
                    <span>Validating Account...</span>
                }
                else
                {
                    <span>LOG IN</span>
                }
            </button>
        </form>

        <div class="portal-info-footer text-center mt-4">
            <p class="m-0 text-dark fw-bold" style="letter-spacing: 0.3px;">Admin Access Only.</p>
        </div>

    </div>
</div>

<style>
    /* Absolute full-screen wrapper style with a premium high-quality cozy cafe background image overlay */
    .auth-viewport-wrapper {
        position: fixed;
        top: 0;
        left: 0;
        width: 100vw;
        height: 100vh;
        z-index: 999999;
        display: flex;
        align-items: center;
        justify-content: center;
        /* Professional stock imagery for elegant aesthetic appeal */
        background: linear-gradient(rgba(17, 34, 51, 0.65), rgba(30, 58, 95, 0.75)), 
                    url('https://images.unsplash.com/photo-1501339847302-ac426a4a7cbb?q=80&w=1600&auto=format&fit=crop') no-repeat center center;
        background-size: cover;
        padding: 20px;
        box-sizing: border-box;
        font-family: 'Segoe UI', system-ui, -apple-system, sans-serif;
    }

    .auth-card-panel {
        background: rgba(255, 255, 255, 0.98);
        border-radius: 16px;
        width: 100%;
        max-width: 455px;
        padding: 45px 40px;
        box-shadow: 0 20px 40px rgba(0, 0, 0, 0.4);
        border: 1px solid rgba(255, 255, 255, 0.8);
        backdrop-filter: blur(10px);
    }

    .brand-avatar {
        width: 65px;
        height: 65px;
        background: #1e3a5f;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 18px;
        box-shadow: 0 4px 12px rgba(30, 58, 95, 0.3);
    }

    .avatar-glyph { font-size: 30px; }
    .brand-title { color: #112233; font-weight: 700; font-size: 1.5rem; margin-bottom: 8px; letter-spacing: -0.3px; }
    
    .institution-sub-badge {
        background: #edf2f7;
        color: #2b6cb0;
        padding: 5px 14px;
        border-radius: 20px;
        font-size: 0.8rem;
        font-weight: 600;
        display: inline-block;
        margin-bottom: 30px;
        border: 1px solid #e2e8f0;
    }

    /* Customized Form Inputs matching the uploaded image spec sheet */
    .input-group-custom {
        display: flex;
        align-items: center;
        background: #f7fafc;
        border: 1px solid #cbd5e0;
        border-radius: 8px;
        padding: 4px 14px;
        transition: all 0.2s ease;
    }

    .input-group-custom:focus-within {
        border-color: #2b6cb0;
        background: #ffffff;
        box-shadow: 0 0 0 3px rgba(66, 153, 225, 0.15);
    }

    .input-icon-node { font-size: 1.1rem; margin-right: 12px; color: #a0aec0; }
    
    .form-control-node {
        border: none;
        background: transparent;
        width: 100%;
        padding: 11px 0;
        outline: none;
        color: #2d3748;
        font-size: 0.95rem;
    }

    .structural-action-row { font-size: 0.85rem; }
    .check-label-text { user-select: none; cursor: pointer; }
    .utility-link { color: #2b6cb0; text-decoration: none; font-weight: 500; }
    .utility-link:hover { text-decoration: underline; }

    .btn-submit-portal {
        background: #112233;
        color: #ffffff;
        width: 100%;
        padding: 14px;
        border-radius: 8px;
        border: none;
        font-weight: 700;
        font-size: 1rem;
        letter-spacing: 0.5px;
        transition: all 0.2s ease-in-out;
        cursor: pointer;
        box-shadow: 0 4px 12px rgba(17, 34, 51, 0.2);
    }

    .btn-submit-portal:hover { 
        background: #2b6cb0; 
        transform: translateY(-1px);
        box-shadow: 0 6px 15px rgba(43, 108, 176, 0.3);
    }
    .btn-submit-portal:disabled { background: #a0aec0; cursor: not-allowed; transform: none; box-shadow: none; }
    
    .portal-info-footer { font-size: 0.9rem; border-top: 1px solid #eee; padding-top: 15px; }
    
    /* Smooth entrance animations */
    .animate-fade { animation: fadeIn 0.4s ease-out-out; }
    @@keyframes fadeIn { from { opacity: 0; transform: translateY(-10px); } to { opacity: 1; transform: translateY(0); } }
</style>

@code {
    private string credentialInput = string.Empty;
    private string passwordInput = string.Empty;
    private string feedbackMessage = string.Empty;
    private bool processingToggle = false;

    private async Task ExecuteAuthenticationAttempt()
    {
        feedbackMessage = string.Empty;
        processingToggle = true;

        try
        {
            var matchedUser = await AuthService.ValidateUserAsync(credentialInput, passwordInput);

            if (matchedUser != null)
            {
                Navigation.NavigateTo("/dashboard", forceLoad: true);
            }
            else
            {
                feedbackMessage = "Access Denied: Invalid parameters matched against user schemas.";
            }
        }
        catch (Exception systemFault)
        {
            feedbackMessage = $"Repository Connectivity Error: {systemFault.Message}";
        }
        finally
        {
            processingToggle = false;
        }
    }
}