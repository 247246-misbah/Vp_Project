@page "/login"
@using Misbah_VisualProgramming_Project.Services
@using Misbah_VisualProgramming_Project.Data
@inject IJSRuntime JSRuntime
@inject AuthService AuthService
@inject NavigationManager Navigation
@rendermode Microsoft.AspNetCore.Components.Web.RenderMode.InteractiveServer

<header class="top-glass-navbar">
    <div class="nav-brand-side">
        <span class="nav-brand-text">CAFE COVE</span>
    </div>
    
    <nav class="nav-links-side">
        <a href="/about" class="portal-nav-link">About Us</a>
        <a href="/contact" class="portal-nav-link">Contact</a>
    </nav>
</header>

<div class="auth-viewport-wrapper">
    <div class="auth-card-panel shadow-lg">
        
        <div class="brand-identity text-center">
            <div class="brand-avatar">
                <svg xmlns="http://www.w3.org/2000/svg" width="45" height="45" fill="#e67e22" class="bi bi-cup-hot-fill" viewBox="0 0 16 16">
                    <path fill-rule="evenodd" d="M.5 11a.5.5 0 0 0 0 1h13a.5.5 0 0 0 0-1H.5Zm11-4H1v3h10.5V7Zm1.5 1v2a1.5 1.5 0 0 0 1.5-1.5V8a1.5 1.5 0 0 0-1.5-1.5H12V7h.5A2.5 2.5 0 0 1 15 9.5v1A2.5 2.5 0 0 1 12.5 13H11.75a.5.5 0 0 1-.354-.146L10.146 11.6a.5.5 0 0 1 .354-.854H12V8h.5Zm-1.72-5.3a.5.5 0 0 1 .124.566l-.75 2a.5.5 0 0 1-.933-.352l.75-2a.5.5 0 0 1 .559-.364Zm-3.5 0a.5.5 0 0 1 .124.566l-.75 2a.5.5 0 0 1-.933-.352l.75-2a.5.5 0 0 1 .559-.364Zm-3.5 0a.5.5 0 0 1 .124.566l-.75 2a.5.5 0 0 1-.933-.352l.75-2a.5.5 0 0 1 .559-.364Z"/>
                </svg>
            </div>
            <h2 class="brand-title">Cafe Cove Management Portal</h2>
            
            <div class="institution-sub-badge">
                <span>Air University Kharian Campus</span>
            </div>
        </div>

        @if (!string.IsNullOrEmpty(feedbackMessage))
        {
            <div class="alert alert-danger border-0 rounded-3 text-center small mb-3" role="alert">
                ⚠️ @feedbackMessage
            </div>
        }

        <form @onsubmit="ExecuteAuthenticationAttempt" @onsubmit:preventDefault>
            
            <div class="mb-3">
                <label class="form-label text-muted fw-semibold small">Email or Username</label>
                <div class="input-group-custom">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-person-fill" viewBox="0 0 16 16">
                        <path d="M3 14s-1 0-1-1 1-4 6-4 6 3 6 4-1 1-1 1zm5-6a3 3 0 1 0 0-6 3 3 0 0 0 0 6"/>
                    </svg>
                    <input type="text" class="form-control-node" @bind="credentialInput" placeholder="administrator" required />
                </div>
            </div>

            <div class="mb-4">
                <label class="form-label text-muted fw-semibold small">Password</label>
                <div class="input-group-custom">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-shield-lock" viewBox="0 0 16 16">
                        <path d="M5.338 1.59a61 61 0 0 0-2.837.856.48.48 0 0 0-.328.39c-.554 4.157.726 7.19 2.253 9.188a10.7 10.7 0 0 0 2.287 2.233c.346.244.652.42.893.533q.18.085.293.118a1 1 0 0 0 .101.025 1 1 0 0 0 .1-.025q.114-.034.294-.118c.24-.113.547-.29.893-.533a10.7 10.7 0 0 0 2.287-2.233c1.527-1.997 2.807-5.031 2.253-9.188a.48.48 0 0 0-.328-.39c-.651-.213-1.75-.56-2.837-.855C9.552 1.29 8.531 1.067 8 1.067c-.53 0-1.552.223-2.662.524zM5.072.56C6.157.265 7.31 0 8 0s1.843.265 2.928.56c1.11.3 2.229.655 2.887.87a1.54 1.54 0 0 1 1.044 1.262c.596 4.477-.787 7.795-2.465 9.99a11.8 11.8 0 0 1-2.517 2.453 7 7 0 0 1-1.048.625c-.28.132-.581.24-.829.24s-.548-.108-.829-.24a7 7 0 0 1-1.048-.625 11.8 11.8 0 0 1-2.517-2.453C1.928 10.487.545 7.169 1.141 2.692A1.54 1.54 0 0 1 2.185 1.43 63 63 0 0 1 5.072.56"/>
                        <path d="M9.5 6.5a1.5 1.5 0 0 1-1 1.415l.385 1.99a.5.5 0 0 1-.491.595h-.788a.5.5 0 0 1-.49-.595l.384-1.99a1.5 1.5 0 1 1 2-1.415"/>
                    </svg>
                    <input type="password" class="form-control-node" @bind="passwordInput" placeholder="••••••••••••" required />
                </div>
            </div>

            <div class="d-flex justify-content-between align-items-center mb-4 structural-action-row text-muted">
                <div class="form-check m-0">
                    <input type="checkbox" class="form-check-input" id="sessionLock" />
                    <label class="form-check-label check-label-text ms-1" for="sessionLock">Remember Me</label>
                </div>
                <a href="javascript:void(0)" class="utility-link">Forgot Password?</a>
            </div>

            <button type="submit" class="btn-submit-portal text-uppercase" disabled="@processingToggle">
                @if (processingToggle)
                {
                    <span class="spinner-border spinner-border-sm me-2" role="status"></span>
                    <span>Validating...</span>
                }
                else
                {
                    <span>LOG IN</span>
                }
            </button>
        </form>

        <div class="portal-info-footer text-center mt-4">
            <p class="m-0 text-dark fw-bold" style="letter-spacing: 0.3px;">Admin Access Only.</p>
        </div>

    </div>
</div>

<style>
    /* TOP NAVIGATION BAR STYLING */
    .top-glass-navbar {
        position: fixed;
        top: 0;
        left: 0;
        width: 100vw;
        height: 70px;
        background: rgba(18, 10, 6, 0.4);
        backdrop-filter: blur(15px);
        -webkit-backdrop-filter: blur(15px);
        border-bottom: 1px solid rgba(255, 255, 255, 0.08);
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 0 50px;
        box-sizing: border-box;
        z-index: 10000;
    }

    .nav-brand-side {
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .nav-brand-text {
        color: #ffffff;
        font-weight: 800;
        letter-spacing: 1.5px;
        font-size: 1.2rem;
        font-family: 'Segoe UI', sans-serif;
    }

    .nav-links-side {
        display: flex;
        align-items: center;
        gap: 35px;
    }

    .portal-nav-link {
        background: none;
        border: none;
        color: #ffffff;
        text-decoration: none;
        font-size: 0.85rem;
        text-transform: uppercase;
        letter-spacing: 1.5px;
        font-weight: 600;
        opacity: 0.75;
        transition: all 0.2s ease;
        cursor: pointer;
        padding: 0;
    }

    .portal-nav-link:hover {
        opacity: 1;
        color: #e67e22;
    }

    /* FULL VIEWPORT MAIN CONTAINER */
    .auth-viewport-wrapper {
        position: fixed;
        top: 0;
        left: 0;
        width: 100vw;
        height: 100vh;
        z-index: 9999;
        display: flex;
        align-items: center;      
        justify-content: center;  
        background: linear-gradient(rgba(0, 0, 0, 0.55), rgba(0, 0, 0, 0.65)), 
                    url('https://images.unsplash.com/photo-1501339847302-ac426a4a7cbb?q=80&w=1600&auto=format&fit=crop') no-repeat center center;
        background-size: cover;
        padding: 20px;
        box-sizing: border-box;
        padding-top: 70px;
    }

    .auth-card-panel {
        background: rgba(255, 255, 255, 0.98);
        border-radius: 16px;
        width: 100%;
        max-width: 440px;
        padding: 40px;
        box-shadow: 0 20px 40px rgba(0, 0, 0, 0.45);
        border: 1px solid rgba(255, 255, 255, 0.8);
    }

    /* REFINED BRAND AVATAR (TRANSPARENT BACKGROUND & SPACING) */
    .brand-avatar {
        width: 65px;
        height: 65px;
        background: transparent;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 12px;
    }

    .brand-title { color: #112233; font-weight: 700; font-size: 1.45rem; margin-bottom: 6px; letter-spacing: -0.3px; }
    
    .institution-sub-badge {
        background: #edf2f7;
        color: #2b6cb0;
        padding: 4px 14px;
        border-radius: 20px;
        font-size: 0.8rem;
        font-weight: 600;
        display: inline-block;
        margin-bottom: 25px;
        border: 1px solid #e2e8f0;
    }

    .input-group-custom {
        display: flex;
        align-items: center;
        background: #f7fafc;
        border: 1px solid #cbd5e0;
        border-radius: 8px;
        padding: 4px 14px;
        transition: all 0.2s ease;
        gap: 10px;
    }

    .input-group-custom svg {
        color: #a0aec0;
    }

    .input-group-custom:focus-within {
        border-color: #e67e22; /* Matches the theme accent */
        background: #ffffff;
        box-shadow: 0 0 0 3px rgba(230, 126, 34, 0.15);
    }

    .input-group-custom:focus-within svg {
        color: #e67e22;
    }
    
    .form-control-node {
        border: none;
        background: transparent;
        width: 100%;
        padding: 10px 0;
        outline: none;
        color: #2d3748;
        font-size: 0.95rem;
    }

    .structural-action-row { font-size: 0.85rem; }
    .check-label-text { user-select: none; cursor: pointer; }
    .utility-link { color: #2b6cb0; text-decoration: none; font-weight: 500; }
    .utility-link:hover { text-decoration: underline; }

    .btn-submit-portal {
        background: #112233;
        color: #ffffff;
        width: 100%;
        padding: 14px;
        border-radius: 8px;
        border: none;
        font-weight: 700;
        font-size: 1rem;
        letter-spacing: 0.5px;
        transition: all 0.2s ease-in-out;
        cursor: pointer;
    }

    .btn-submit-portal:hover { background: #e67e22; }
    .portal-info-footer { font-size: 0.9rem; border-top: 1px solid #eee; padding-top: 15px; }
</style>

@code {
    private string credentialInput = string.Empty;
    private string passwordInput = string.Empty;
    private string feedbackMessage = string.Empty;
    private bool processingToggle = false;

    private async Task ExecuteAuthenticationAttempt()
    {
        feedbackMessage = string.Empty;
        processingToggle = true;

        try
        {
            var matchedUser = await AuthService.ValidateUserAsync(credentialInput, passwordInput);

            if (matchedUser != null)
            {
                // Fix: Class Diagram k mutabiq '.Name' ki jga '.Username' use kr rha hu
                string displayName = !string.IsNullOrEmpty(matchedUser.Username) ? matchedUser.Username : credentialInput;
                
                Navigation.NavigateTo($"/dashboard?username={Uri.EscapeDataString(displayName)}", forceLoad: false);
            }
            else
            {
                feedbackMessage = "Access Denied: Invalid Username or Password.";
            }
        }
        catch (Exception systemFault)
        {
            feedbackMessage = $"Database Error: {systemFault.Message}";
        }
        finally
        {
            processingToggle = false;
        }
    }
}