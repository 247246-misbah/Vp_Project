@page "/login"
@using Misbah_VisualProgramming_Project.Services
@using Misbah_VisualProgramming_Project.Data
@inject AuthService AuthService
@inject NavigationManager Navigation
@rendermode Microsoft.AspNetCore.Components.Web.RenderMode.InteractiveServer

<div class="auth-viewport-wrapper">
    <div class="auth-card-panel shadow-lg">
        
        <div class="brand-identity text-center">
            <div class="brand-avatar shadow">
                <span class="avatar-glyph">☕</span>
            </div>
            <h2 class="brand-title">Cafe Cove Management Portal</h2>
            
            <div class="institution-sub-badge">
                <span>Air University Kharian Campus</span>
            </div>
        </div>

        @if (!string.IsNullOrEmpty(feedbackMessage))
        {
            <div class="alert alert-danger border-0 rounded-3 text-center small mb-3 animate-fade" role="alert">
                ⚠️ @feedbackMessage
            </div>
        }

        <form @onsubmit="ExecuteAuthenticationAttempt" @onsubmit:preventDefault>
            
            <div class="mb-3">
                <label class="form-label text-muted fw-semibold small">Email or Username</label>
                <div class="input-group-custom">
                    <span class="input-icon-node">👤</span>
                    <input type="text" class="form-control-node" @bind="credentialInput" placeholder="administrator" required />
                </div>
            </div>

            <div class="mb-4">
                <label class="form-label text-muted fw-semibold small">Password</label>
                <div class="input-group-custom">
                    <span class="input-icon-node">🔒</span>
                    <input type="password" class="form-control-node" @bind="passwordInput" placeholder="••••••••••••" required />
                </div>
            </div>

            <div class="d-flex justify-content-between align-items-center mb-4 structural-action-row text-muted">
                <div class="form-check m-0">
                    <input type="checkbox" class="form-check-input" id="sessionLock" />
                    <label class="form-check-label check-label-text ms-1" for="sessionLock">Remember Me</label>
                </div>
                <a href="javascript:void(0)" class="utility-link">Forgot Password?</a>
            </div>

            <button type="submit" class="btn-submit-portal text-uppercase" disabled="@processingToggle">
                @if (processingToggle)
                {
                    <span class="spinner-border spinner-border-sm me-2" role="status"></span>
                    <span>Validating Account...</span>
                }
                else
                {
                    <span>LOG IN</span>
                }
            </button>
        </form>

        <div class="portal-info-footer text-center mt-4">
            <p class="mb-1 text-muted">Staff & Faculty Access Only.</p>
            <p class="m-0 text-muted">For student portals, <a href="javascript:void(0)" class="utility-link fw-semibold">click here.</a></p>
        </div>

    </div>
</div>

<style>
    /* Absolute full-screen wrapper style to lock background canvas leaking */
    .auth-viewport-wrapper {
        position: fixed;
        top: 0;
        left: 0;
        width: 100vw;
        height: 100vh;
        z-index: 999999;
        display: flex;
        align-items: center;
        justify-content: center;
        background: linear-gradient(135deg, #112233 0%, #1e3a5f 100%);
        padding: 20px;
        box-sizing: border-box;
        font-family: 'Segoe UI', system-ui, -apple-system, sans-serif;
    }

    .auth-card-panel {
        background: #ffffff;
        border-radius: 12px;
        width: 100%;
        max-width: 460px;
        padding: 40px;
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.25);
        border: 1px solid rgba(0, 0, 0, 0.05);
    }

    .brand-avatar {
        width: 60px;
        height: 60px;
        background: #1e3a5f;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 15px;
    }

    .avatar-glyph { font-size: 28px; }
    .brand-title { color: #112233; font-weight: 700; font-size: 1.45rem; margin-bottom: 8px; letter-spacing: -0.3px; }
    
    .institution-sub-badge {
        background: #edf2f7;
        color: #2b6cb0;
        padding: 5px 14px;
        border-radius: 20px;
        font-size: 0.8rem;
        font-weight: 600;
        display: inline-block;
        margin-bottom: 30px;
        border: 1px solid #e2e8f0;
    }

    /* Customized Form Inputs matching the uploaded image spec sheet */
    .input-group-custom {
        display: flex;
        align-items: center;
        background: #f7fafc;
        border: 1px solid #cbd5e0;
        border-radius: 6px;
        padding: 4px 12px;
        transition: border-color 0.2s;
    }

    .input-group-custom:focus-within {
        border-color: #2b6cb0;
        background: #ffffff;
        box-shadow: 0 0 0 3px rgba(66, 153, 225, 0.15);
    }

    .input-icon-node { font-size: 1.1rem; margin-right: 10px; color: #a0aec0; }
    
    .form-control-node {
        border: none;
        background: transparent;
        width: 100%;
        padding: 10px 0;
        outline: none;
        color: #2d3748;
        font-size: 0.95rem;
    }

    .structural-action-row { font-size: 0.85rem; }
    .check-label-text { user-select: none; cursor: pointer; }
    .utility-link { color: #2b6cb0; text-decoration: none; font-weight: 500; }
    .utility-link:hover { text-decoration: underline; }

    .btn-submit-portal {
        background: #112233;
        color: #ffffff;
        width: 100%;
        padding: 14px;
        border-radius: 6px;
        border: none;
        font-weight: 700;
        font-size: 0.95rem;
        letter-spacing: 0.5px;
        transition: background 0.2s;
        cursor: pointer;
    }

    .btn-submit-portal:hover { background: #2b6cb0; }
    .btn-submit-portal:disabled { background: #a0aec0; cursor: not-allowed; }
    
    .portal-info-footer { font-size: 0.8rem; line-height: 1.4; }
    .animate-fade { animation: fadeIn 0.3s ease-in-out; }
    @@keyframes fadeIn { from { opacity: 0; transform: translateY(-5px); } to { opacity: 1; transform: translateY(0); } }
</style>

@code {
    private string credentialInput = string.Empty;
    private string passwordInput = string.Empty;
    private string feedbackMessage = string.Empty;
    private bool processingToggle = false;

    private async Task ExecuteAuthenticationAttempt()
    {
        feedbackMessage = string.Empty;
        processingToggle = true;

        try
        {
            var matchedUser = await AuthService.ValidateUserAsync(credentialInput, passwordInput);

            if (matchedUser != null)
            {
                // Successful login triggers dynamic hard reset transition to secure area
                Navigation.NavigateTo("/dashboard", forceLoad: true);
            }
            else
            {
                feedbackMessage = "Access Denied: Invalid parameters matched against user schemas.";
            }
        }
        catch (Exception systemFault)
        {
            feedbackMessage = $"Repository Connectivity Error: {systemFault.Message}";
        }
        finally
        {
            processingToggle = false;
        }
    }
}