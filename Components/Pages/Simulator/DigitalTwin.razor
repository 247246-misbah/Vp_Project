@page "/hardware-simulator"

<div class="container-fluid fade-in">
    <div class="mb-4">
        <h3 class="fw-bold m-0 text-dark">Digital Twin Telemetry Simulator</h3>
        <p class="text-muted m-0">Virtual monitoring matrix for real-time espresso brewing temperature sensors and security alerts.</p>
    </div>

    <div class="row g-4">
        <div class="col-lg-6">
            <div class="cafe-card p-4 border bg-white shadow-sm h-100">
                <div class="d-flex justify-content-between align-items-center mb-4 border-bottom pb-2">
                    <h5 class="fw-bold m-0 text-dark">🛠️ Espresso Station #1 (Digital Twin)</h5>
                    <span class="badge bg-success rounded-pill px-3">Active Streaming</span>
                </div>

                <div class="p-4 bg-light rounded-4 text-center my-4 border">
                    <span class="text-muted text-uppercase small d-block fw-bold tracking-wider mb-1">Boiler Temperature Telemetry</span>
                    <h1 class="display-3 fw-bold text-dark m-0">93.4°C</h1>
                    <span class="text-success small fw-semibold">🟢 Optimal Brewing Range State</span>
                </div>

                <div class="d-flex justify-content-around mt-4">
                    <button class="btn btn-sm btn-dark rounded-pill px-4 py-2">⚡ Trigger Extraction Cycle</button>
                    <button class="btn btn-sm btn-outline-danger rounded-pill px-4 py-2">🛑 Emergency Shutdown</button>
                </div>
            </div>
        </div>

        <div class="col-lg-6">
            <div class="cafe-card p-4 border bg-white shadow-sm h-100">
                <div class="d-flex justify-content-between align-items-center mb-4 border-bottom pb-2">
                    <h5 class="fw-bold m-0 text-dark">🔒 Facility Core Gateway Security Matrix</h5>
                    <span class="badge bg-dark rounded-pill px-3">Bit-Mask Controls</span>
                </div>
                
                <p class="text-muted small">Simulating physical door lock registries and smoke detector relays using binary state evaluations.</p>

                <div class="list-group list-group-flush my-4 border rounded-3 overflow-hidden">
                    <div class="list-group-item d-flex justify-content-between align-items-center p-3">
                        <div>
                            <h6 class="fw-bold m-0 text-dark">Main Entrance Security Deadbolt</h6>
                            <small class="text-muted">Register Memory Node Location: Bit 0</small>
                        </div>
                        <span class="badge bg-success-subtle text-success border border-success-subtle px-3 py-2 rounded-pill">SECURED (1)</span>
                    </div>

                    <div class="list-group-item d-flex justify-content-between align-items-center p-3">
                        <div>
                            <h6 class="fw-bold m-0 text-dark">Kitchen Zone 1 Thermal Smoke Relay</h6>
                            <small class="text-muted">Register Memory Node Location: Bit 1</small>
                        </div>
                        <span class="badge bg-danger-subtle text-danger border border-danger-subtle px-3 py-2 rounded-pill">ALERT TRIGGERED (0)</span>
                    </div>
                </div>

                <button class="btn btn-outline-dark w-100 py-2.5 rounded-pill fw-bold">
                    🔄 Recalculate Register Bitwise Operations
                </button>
            </div>
        </div>
    </div>
</div>