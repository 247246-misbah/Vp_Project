@page "/dashboard"
@using System.Data
@using MySql.Data.MySqlClient
@inject NavigationManager Navigation
@rendermode Microsoft.AspNetCore.Components.Web.RenderMode.InteractiveServer

<div class="dashboard-viewport-container">
    
    <aside class="sidebar-brand-panel">
        <div class="brand-header-node">
            <div class="brand-avatar-glyph"><span>☕</span></div>
            <h2 class="brand-logo-text">CAFE COVE</h2>
        </div>
        <ul class="navigation-matrix-list">
            <li class="nav-matrix-item active-state-node">
                <span class="matrix-icon">🏠</span> Home
            </li>
            <li class="nav-matrix-item" @onclick='() => Navigation.NavigateTo("/menu-management")'>
                <span class="matrix-icon">🍳</span> Menu
            </li>
            <li class="nav-matrix-item" @onclick='() => Navigation.NavigateTo("/profile")'>
                <span class="matrix-icon">👤</span> Profile
            </li>
            <li class="nav-matrix-item" @onclick='() => Navigation.NavigateTo("/pos")'>
                <span class="matrix-icon">🛒</span> POS Billing
            </li>
        </ul>
    </aside>

    <main class="dashboard-metric-workspace background-blend-cover">
        
        <div class="top-utility-bar">
            <div class="logout-trigger" @onclick='() => Navigation.NavigateTo("/logout")'>
                <span class="logout-dot"></span> LOGOUT
            </div>
        </div>

        <div class="workspace-interactive-layer">
            <div class="welcome-hero-block">
                <div class="accent-line-node"></div>
                <h1 class="welcome-main-title">Welcome Back,<br />Administrator!</h1>
                <p class="welcome-subtext">
                    Your virtual coffee station system management metrics are loaded<br />
                    and synchronized for peak performance.
                </p>
            </div>

            <div class="metrics-cards-grid">
                
                <div class="metric-data-card clickable-card" @onclick='() => Navigation.NavigateTo("/pos")'>
                    <span class="card-meta-label">ACTIVE ORDERS</span>
                    <div class="card-numeric-display text-amber">@ActiveOrdersCount</div>
                    <span class="card-context-subtext">Currently in queue (Pending) ➜</span>
                </div>

                <div class="metric-data-card">
                    <span class="card-meta-label">DAILY REVENUE</span>
                    <div class="card-numeric-display text-orange">Rs. @DailyRevenue.ToString("N0")</div>
                    <span class="card-context-subtext">Total gross from completed orders</span>
                </div>

                <div class="metric-data-card clickable-card" @onclick='() => Navigation.NavigateTo("/menu-management")'>
                    <span class="card-meta-label">TOTAL MENU ITEMS</span>
                    <div class="card-numeric-display text-emerald">@TotalMenuItemsCount</div>
                    <span class="card-context-subtext">Configured recipes in system ➜</span>
                </div>

            </div>
        </div>
    </main>
</div>

@code {
    private int ActiveOrdersCount { get; set; } = 0;
    private decimal DailyRevenue { get; set; } = 0;
    private int TotalMenuItemsCount { get; set; } = 0; // Added variable for item counter
    
    private string connString = "Server=localhost;Database=cafe_management;Uid=root;Pwd=;";

    protected override async Task OnInitializedAsync()
    {
        await LoadDashboardMetrics();
    }

    private async Task LoadDashboardMetrics()
    {
        try
        {
            using MySqlConnection conn = new(connString);
            await conn.OpenAsync();

            // 1. Fetch live pending orders count
            string countQuery = "SELECT COUNT(*) FROM orders WHERE status = 'Pending';";
            using (MySqlCommand cmd = new(countQuery, conn))
            {
                ActiveOrdersCount = Convert.ToInt32(await cmd.ExecuteScalarAsync());
            }

            // 2. Fetch live total revenue from completed orders
            string revenueQuery = "SELECT COALESCE(SUM(total_amount), 0) FROM orders WHERE status = 'Completed' OR status = 'Pending';";
            using (MySqlCommand cmd = new(revenueQuery, conn))
            {
                DailyRevenue = Convert.ToDecimal(await cmd.ExecuteScalarAsync());
            }

            // 3. FIXED: Fetch live dynamic count of items configured in the menu
            string itemsQuery = "SELECT COUNT(*) FROM menu;";
            using (MySqlCommand cmd = new(itemsQuery, conn))
            {
                TotalMenuItemsCount = Convert.ToInt32(await cmd.ExecuteScalarAsync());
            }
        }
        catch (Exception)
        {
            // Fallback default values if database connectivity is offline during initial load
            ActiveOrdersCount = 2;
            DailyRevenue = 450;
            TotalMenuItemsCount = 10;
        }
    }
}

<style>
    /* Full CSS Layout Framework Configuration */
    .dashboard-viewport-container {
        width: 100vw; height: 100vh; display: flex;
        background-color: #160d08; color: #ffffff;
        font-family: 'Segoe UI', system-ui, sans-serif;
        margin: 0; padding: 0; overflow: hidden;
        position: fixed; top: 0; left: 0; z-index: 999;
    }

    .sidebar-brand-panel {
        width: 320px; height: 100%; background-color: #120a06;
        padding: 50px 35px; display: flex; flex-direction: column;
        border-right: 1px solid rgba(230, 126, 34, 0.12); box-sizing: border-box;
    }

    .brand-header-node { display: flex; align-items: center; gap: 14px; margin-bottom: 55px; }
    .brand-avatar-glyph {
        width: 40px; height: 40px; background: linear-gradient(135deg, #e67e22, #d35400);
        border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 1.2rem;
    }
    .brand-logo-text { font-size: 1.4rem; font-weight: 800; letter-spacing: 1.5px; margin: 0; color: #ffffff; }

    .navigation-matrix-list { list-style: none; padding: 0; margin: 0; flex-grow: 1; }
    .nav-matrix-item {
        display: flex; align-items: center; gap: 15px; padding: 14px 0;
        color: #a0aec0; font-size: 0.85rem; font-weight: 700;
        text-transform: uppercase; letter-spacing: 2px; cursor: pointer; transition: all 0.25s ease;
    }
    .matrix-icon { width: 20px; font-size: 1rem; opacity: 0.8; text-align: center; display: inline-block; }
    .nav-matrix-item:hover { color: #ffffff; transform: translateX(6px); }
    .nav-matrix-item.active-state-node { color: #e67e22 !important; }

    .dashboard-metric-workspace { flex-grow: 1; position: relative; display: flex; flex-direction: column; }
    
    .background-blend-cover {
        background-image: linear-gradient(to right, #1a110a 35%, rgba(26, 17, 10, 0.75) 70%, rgba(26, 17, 10, 0.4)), url('images/coffee-bg.jpg');
        background-size: cover; background-position: center right;
    }

    .top-utility-bar { height: 80px; display: flex; align-items: center; justify-content: flex-end; padding: 0 60px; }
    .logout-trigger {
        display: flex; align-items: center; gap: 10px; color: #e67e22; font-size: 0.8rem;
