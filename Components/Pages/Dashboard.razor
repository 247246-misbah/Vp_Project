@page "/dashboard"
@using Misbah_VisualProgramming_Project.Services
@using Misbah_VisualProgramming_Project.Models
@inject HardwareService HardwareService
@implements IDisposable

<div class="container-fluid py-4 px-4" style="background-color: #fdfbf7; min-height: 100vh;">
    <div class="row mb-4">
        <div class="col-12">
            <div class="card border-0 shadow-sm overflow-hidden position-relative rounded-4 text-white"
                 style="background: linear-gradient(rgba(0,0,0,0.55), rgba(0,0,0,0.55)), url('https://images.unsplash.com/photo-1501339847302-ac426a4a7cbb?q=80&w=1200') center/cover; min-height: 200px;">
                <div class="card-body p-4 p-md-5 d-flex justify-content-between align-items-center flex-wrap position-relative z-1">
                    <div>
                        <span class="badge bg-warning text-dark mb-2 px-3 py-2 rounded-pill fw-bold text-uppercase small">A Real Italian Cafe</span>
                        <h1 class="display-6 fw-bold mb-1" style="font-family: 'Playfair Display', serif;">Discover the Taste of Real Coffee</h1>
                        <p class="mb-0 text-white-50">Hardware Simulation & Digital Twin Monitoring Station</p>
                    </div>
                    <div class="mt-3 mt-lg-0">
                        @if (machine.IsConnected)
                        {
                            <span class="badge bg-white text-success px-4 py-3 fs-6 shadow rounded-pill fw-bold border-0">● Active Twin System</span>
                        }
                        else
                        {
                            <span class="badge bg-danger text-white px-4 py-3 fs-6 shadow rounded-pill fw-bold">● System Disconnected</span>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-lg-4 col-md-12">
            <div class="card h-100 shadow-sm border-0 rounded-4 bg-white p-4">
                <div class="d-flex align-items-center justify-content-between mb-3">
                    <h5 class="fw-bold text-muted mb-0" style="font-family: 'Playfair Display', serif;">Core Framework</h5>
                    <span class="fs-4">⚙️</span>
                </div>
                <h3 class="fw-extrabold text-dark mb-3">@machine.MachineName</h3>
                
                <div class="p-3 rounded-4 mb-4" style="background-color: #fbf8f3; border: 1px solid #efe5d5;">
                    <div class="d-flex align-items-center mb-1">
                        <div class="spinner-grow text-warning spinner-grow-sm me-2" role="status"></div>
                        <span class="text-muted small fw-bold">CURRENT PROCESS STATE</span>
                    </div>
                    <div class="fs-5 fw-bold text-dark">@machine.CurrentState</div>
                </div>

                <button class="btn text-white btn-lg w-100 fw-bold shadow-sm py-3 mt-auto rounded-3"
                        style="background-color: #6f4e37; border: none; transition: transform 0.2s;"
                        onmouseover="this.style.transform='scale(1.02)'" onmouseout="this.style.transform='scale(1)'"
                        @onclick="TriggerBrewCycle">
                    ☕ Run Espresso Extraction
                </button>
            </div>
        </div>

        <div class="col-lg-8 col-md-12">
            <div class="card h-100 shadow-sm border-0 rounded-4 bg-white p-4">
                <h5 class="fw-bold text-dark mb-4" style="font-family: 'Playfair Display', serif;">Live Coffee Machine Telemetry</h5>
                <div class="row g-4">
                    
                    <div class="col-md-6">
                        <div class="p-3 rounded-4 border-0 shadow-sm" style="background-color: #fdfbf7;">
                            <div class="d-flex justify-content-between align-items-center mb-2">
                                <span class="fw-semibold text-secondary small">🌡️ BOILER TEMPERATURE</span>
                                <span class="badge bg-danger bg-opacity-10 text-danger fs-6 fw-bold rounded-pill px-3">@machine.Temperature.ToString("F1")°C</span>
                            </div>
                            <div class="progress bg-secondary bg-opacity-10" style="height: 12px; border-radius: 10px;">
                                <div class="progress-bar progress-bar-striped progress-bar-animated bg-danger"
                                     role="progressbar" style="width: @(machine.Temperature)%"></div>
                            </div>
                        </div>
                    </div>

                    <div class="col-md-6">
                        <div class="p-3 rounded-4 border-0 shadow-sm" style="background-color: #fdfbf7;">
                            <div class="d-flex justify-content-between align-items-center mb-2">
                                <span class="fw-semibold text-secondary small">💧 WATER RESERVOIR STATUS</span>
                                <span class="badge bg-info bg-opacity-10 text-info fs-6 fw-bold rounded-pill px-3">@machine.WaterLevel%</span>
                            </div>
                            <div class="progress bg-secondary bg-opacity-10" style="height: 12px; border-radius: 10px;">
                                <div class="progress-bar progress-bar-striped bg-info"
                                     role="progressbar" style="width: @machine.WaterLevel%"></div>
                            </div>
                        </div>
                    </div>

                    <div class="col-12">
                        <div class="p-4 rounded-4 border-0 shadow-sm" style="background-color: #fdfbf7;">
                            <div class="d-flex justify-content-between align-items-center mb-2">
                                <span class="fw-semibold text-secondary small">🫘 COFFEE BEANS HOPPER CAPACITY</span>
                                <span class="badge bg-dark fs-6 fw-bold rounded-pill px-3 text-warning">@machine.BeanWeight g / 500g</span>
                            </div>
                            <div class="progress bg-secondary bg-opacity-10" style="height: 16px; border-radius: 10px;">
                                <div class="progress-bar progress-bar-striped"
                                     role="progressbar" style="width: @((machine.BeanWeight / 500.0) * 100)%; background-color: #8b5a2b;"></div>
                            </div>
                        </div>
                    </div>

                </div>
            </div>
        </div>
    </div>
</div>

@code {
    private HardwareStatus machine = new();
    private System.Threading.Timer? simulationTimer;

    protected override async Task OnInitializedAsync()
    {
        machine = await HardwareService.GetLatestStatus();
        
        simulationTimer = new System.Threading.Timer(_ =>
        {
            InvokeAsync(() =>
            {
                var random = new Random();
                machine.Temperature += random.NextDouble() * 2.0 - 1.0;
                if (machine.Temperature > 96) machine.Temperature = 91;
                if (machine.Temperature < 88) machine.Temperature = 92;
                StateHasChanged();
            });
        }, null, 2000, 2000);
    }

    private void TriggerBrewCycle()
    {
        machine.CurrentState = "Extracting Rich Crema Espresso Shot...";
        machine.WaterLevel -= 4;
        machine.BeanWeight -= 15;
        
        if (machine.WaterLevel < 20) machine.WaterLevel = 95;
        if (machine.BeanWeight < 50) machine.BeanWeight = 450;
    }

    public void Dispose()
    {
        simulationTimer?.Dispose();
    }
}