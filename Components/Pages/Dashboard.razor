@page "/dashboard"
@using Misbah_VisualProgramming_Project.Models
@using Misbah_VisualProgramming_Project.Services
@inject HardwareService Hardware
@implements IDisposable

<link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet">

<div style="font-family: 'Plus Jakarta Sans', sans-serif; padding: 40px; color: #ffffff; min-height: 100vh; background: #0d0b0a;">
    
    <div style="border-bottom: 1px solid rgba(255,255,255,0.08); padding-bottom: 24px; margin-bottom: 40px; display: flex; justify-content: space-between; align-items: center;">
        <div>
            <h1 style="font-size: 32px; font-weight: 700; background: linear-gradient(135deg, #f59e0b 0%, #d97706 100%); -webkit-background-clip: text; -webkit-text-fill-color: transparent; margin: 0; letter-spacing: 0.5px;">
                📊 COFFEE COVE DIGITAL TWIN
            </h1>
            <p style="color: #9ca3af; font-size: 13px; margin: 6px 0 0 0; text-transform: uppercase; letter-spacing: 1.5px;">
                Hardware Telemetry Canvas • Simulation Mode Active
            </p>
        </div>
        
        <div style="padding: 8px 18px; border-radius: 30px; font-size: 11px; font-weight: 700; letter-spacing: 1px; display: flex; align-items: center; gap: 8px;
            background: rgba(16, 185, 129, 0.1); color: #10b981; border: 1px solid rgba(16, 185, 129, 0.25);">
            <span style="width: 8px; height: 8px; background: #10b981; border-radius: 50%; display: inline-block;"></span>
            SYSTEM ONLINE
        </div>
    </div>

    @if (telemetry == null)
    {
        <div style="display: flex; flex-direction: column; align-items: center; justify-content: center; min-height: 300px;">
            <div class="spinner-border text-warning" role="status" style="width: 3rem; height: 3rem;"></div>
            <p style="color: #9ca3af; margin-top: 20px; font-size: 13px; text-transform: uppercase;">Booting UI Scaffolding...</p>
        </div>
    }
    else
    {
        <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(270px, 1fr)); gap: 30px;">
            
            <div class="luxury-card" style="background: rgba(28, 24, 22, 0.65); border: 1px solid rgba(245, 158, 11, 0.12); border-radius: 24px; padding: 28px; box-shadow: 0 15px 35px rgba(0,0,0,0.4);">
                <div style="font-size: 24px; margin-bottom: 15px;">🤖</div>
                <span style="color: #d97706; font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: 1.5px;">Twin Node Profile</span>
                <h3 style="font-size: 22px; font-weight: 700; color: #ffffff; margin: 12px 0 16px 0;">@telemetry.MachineName</h3>
                <span style="background: rgba(245, 158, 11, 0.1); border: 1px solid rgba(245, 158, 11, 0.2); padding: 6px 14px; border-radius: 12px; font-size: 12px; color: #f59e0b; font-weight: 600; display: inline-block;">
                    ⚙️ @telemetry.CurrentState
                </span>
            </div>

            <div class="luxury-card" style="background: rgba(28, 24, 22, 0.65); border: 1px solid rgba(239, 68, 68, 0.12); border-radius: 24px; padding: 28px; box-shadow: 0 15px 35px rgba(0,0,0,0.4);">
                <div style="font-size: 24px; margin-bottom: 15px;">🔥</div>
                <span style="color: #ef4444; font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: 1.5px;">Boiler Core Temperature</span>
                <h3 style="font-size: 34px; font-weight: 700; color: #ffffff; margin: 10px 0 18px 0;">@telemetry.Temperature.ToString("F1")°C</h3>
                <div style="height: 6px; background: rgba(255,255,255,0.03); border-radius: 10px; overflow: hidden;">
                    <div style="height: 100%; background: linear-gradient(90deg, #ef4444, #f97316); width: @(Math.Min(telemetry.Temperature / 120.0 * 100.0, 100.0))%; border-radius: 10px;"></div>
                </div>
            </div>

            <div class="luxury-card" style="background: rgba(28, 24, 22, 0.65); border: 1px solid rgba(59, 130, 246, 0.12); border-radius: 24px; padding: 28px; box-shadow: 0 15px 35px rgba(0,0,0,0.4);">
                <div style="font-size: 24px; margin-bottom: 15px;">💧</div>
                <span style="color: #3b82f6; font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: 1.5px;">Water Level Reservoir</span>
                <h3 style="font-size: 34px; font-weight: 700; color: #ffffff; margin: 10px 0 18px 0;">@telemetry.WaterLevel%</h3>
                <div style="height: 6px; background: rgba(255,255,255,0.03); border-radius: 10px; overflow: hidden;">
                    <div style="height: 100%; background: linear-gradient(90deg, #3b82f6, #06b6d4); width: @telemetry.WaterLevel%; border-radius: 10px;"></div>
                </div>
            </div>

            <div class="luxury-card" style="background: rgba(28, 24, 22, 0.65); border: 1px solid rgba(16, 185, 129, 0.12); border-radius: 24px; padding: 28px; box-shadow: 0 15px 35px rgba(0,0,0,0.4);">
                <div style="font-size: 24px; margin-bottom: 15px;">🫘</div>
                <span style="color: #10b981; font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: 1.5px;">Hopper Bean Stock</span>
                <h3 style="font-size: 34px; font-weight: 700; color: #ffffff; margin: 10px 0 18px 0;">@telemetry.BeanWeight <span style="font-size: 16px; color: #6b7280; font-weight: 400;">g</span></h3>
                <div style="height: 6px; background: rgba(255,255,255,0.03); border-radius: 10px; overflow: hidden;">
                    <div style="height: 100%; background: linear-gradient(90deg, #10b981, #84cc16); width: @(Math.Min(telemetry.BeanWeight / 500.0 * 100.0, 100.0))%; border-radius: 10px;"></div>
                </div>
            </div>

        </div>
    }
</div>

<style>
    .luxury-card {
        transition: transform 0.3s ease, border-color 0.3s ease;
    }

        .luxury-card:hover {
            transform: translateY(-5px);
            border-color: rgba(245, 158, 11, 0.4) !important;
            box-shadow: 0 20px 40px rgba(245, 158, 11, 0.1) !important;
        }
</style>

@code {
    private HardwareStatus? telemetry;
    private System.Threading.Timer? _timer;

    protected override async Task OnInitializedAsync()
    {
        telemetry = await Hardware.GetLatestStatus();

        _timer = new System.Threading.Timer(async _ =>
        {
            await InvokeAsync(async () =>
            {
                telemetry = await Hardware.GetLatestStatus();
                StateHasChanged();
            });
        }, null, 2500, 2500);
    }

    public void Dispose()
    {
        _timer?.Dispose();
    }
}