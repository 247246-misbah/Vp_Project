@page "/dashboard"
@using System.Data
@using MySql.Data.MySqlClient
@inject NavigationManager Navigation
@rendermode Microsoft.AspNetCore.Components.Web.RenderMode.InteractiveServer

<div class="dashboard-viewport-container">
    
    <aside class="sidebar-brand-panel">
        <div class="brand-header-node">
            <div class="brand-avatar-glyph">
                <span>☕</span>
            </div>
            <h2 class="brand-logo-text">CAFE COVE</h2>
        </div>

        <ul class="navigation-matrix-list">
            <li class="nav-matrix-item active-state-node">
                <span class="matrix-icon">🏠</span> Home
            </li>
            
            <li class="nav-matrix-item" @onclick='() => Navigation.NavigateTo("/menu-management")'>
                <span class="matrix-icon">🍳</span> Menu
            </li>
            
            <li class="nav-matrix-item" @onclick='() => Navigation.NavigateTo("/profile")'>
                <span class="matrix-icon">👤</span> Profile
            </li>
        </ul>
    </aside>

    <main class="dashboard-metric-workspace">
        <div class="scrimmed-hero-viewport"></div>
        
        <div class="workspace-interactive-layer">
            <nav class="top-row-utility-bar">
                <a href="/login" class="session-termination-link">
                    <span class="power-glyph">⭕</span> Logout 
                </a>
            </nav>

            <div class="hero-typography-block">
                <div class="aesthetic-brand-divider"></div>
                <h1 class="hero-main-title">Welcome Back,<br />Administrator!</h1>
                <p class="hero-subtext-para">Your virtual coffee station system management metrics are loaded and synchronized for peak performance.</p>
            </div>

            <div class="metrics-structural-row-grid">
                
                <div class="metric-card-node">
                    <div class="metric-label-tag">Active Orders</div>
                    <div class="metric-primary-value">@ActiveOrdersCount</div>
                    <div class="metric-desc-label">Currently in queue (Pending)</div>
                </div>

                <div class="metric-card-node">
                    <div class="metric-label-tag">Daily Revenue</div>
                    <div class="metric-primary-value">Rs. @DailyRevenue.ToString("N0")</div>
                    <div class="metric-desc-label">Total gross from completed orders</div>
                </div>

                <div class="metric-card-node">
                    <div class="metric-label-tag">Machine Status</div>
                    <div class="metric-primary-value status-optimal-green">Optimal</div>
                    <div class="metric-desc-label">All systems operational</div>
                </div>

            </div>
        </div>
    </main>
</div>

@code {
    private int ActiveOrdersCount { get; set; } = 0;
    private decimal DailyRevenue { get; set; } = 0;
    private string connString = "Server=localhost;Database=cafe_management;Uid=root;Pwd=;";

    protected override async Task OnInitializedAsync()
    {
        await LoadDashboardMetrics();
    }

    private async Task LoadDashboardMetrics()
    {
        try
        {
            using MySqlConnection conn = new(connString);
            await conn.OpenAsync();

            // 1. Query to get active/pending orders count
            string activeOrdersQuery = "SELECT COUNT(*) FROM orders WHERE status = 'Pending';";
            using MySqlCommand cmd1 = new(activeOrdersQuery, conn);
            ActiveOrdersCount = Convert.ToInt32(await cmd1.ExecuteScalarAsync());

            // 2. Query to get daily revenue sum (from Completed orders)
            string revenueQuery = "SELECT IFNULL(SUM(total_amount), 0) FROM orders WHERE status = 'Completed' AND DATE(order_date) = CURDATE();";
            using MySqlCommand cmd2 = new(revenueQuery, conn);
            DailyRevenue = Convert.ToDecimal(await cmd2.ExecuteScalarAsync());
        }
        catch (Exception ex)
        {
            // Fallback default values if database has any issue
            ActiveOrdersCount = 0;
            DailyRevenue = 0;
            Console.WriteLine($"Dashboard Data Error: {ex.Message}");
        }
    }
}

<style>
    /* COMPONENT-LEVEL STRUCTURE FOR ABSOLUTE CONTROL */
    .dashboard-viewport-container {
        width: 100vw;
        height: 100vh;
        display: flex;
        background-color: #160d08;
        color: #ffffff;
        font-family: 'Segoe UI', system-ui, -apple-system, sans-serif;
        margin: 0;
        padding: 0;
        overflow: hidden;
        position: fixed;
        top: 0;
        left: 0;
        z-index: 999;
    }

    /* SIDEBAR SYSTEM STYLING */
    .sidebar-brand-panel {
        width: 320px;
        height: 100%;
        background-color: #120a06;
        padding: 50px 35px;
        display: flex;
        flex-direction: column;
        border-right: 1px solid rgba(230, 126, 34, 0.12);
        box-sizing: border-box;
    }

    .brand-header-node {
        display: flex;
        align-items: center;
        gap: 14px;
        margin-bottom: 55px;
    }

    .brand-avatar-glyph {
        width: 40px;
        height: 40px;
        background: linear-gradient(135deg, #e67e22, #d35400);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.2rem;
    }

    .brand-logo-text {
        font-size: 1.4rem;
        font-weight: 800;
        letter-spacing: 1.5px;
        margin: 0;
        color: #ffffff;
    }

    .navigation-matrix-list {
        list-style: none;
        padding: 0;
        margin: 0;
        flex-grow: 1;
    }

    .nav-matrix-item {
        display: flex;
        align-items: center;
        gap: 15px;
        padding: 14px 0;
        color: #a0aec0;
        font-size: 0.85rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 2px;
        cursor: pointer;
        transition: all 0.25s ease;
    }

    .matrix-icon {
        width: 20px;
        font-size: 1rem;
        opacity: 0.8;
        display: inline-block;
        text-align: center;
    }

    .nav-matrix-item:hover {
        color: #ffffff;
        transform: translateX(6px);
    }

    .nav-matrix-item.active-state-node {
        color: #e67e22 !important;
    }

    /* RIGHT WORKSPACE CONTEXT WITH BACKGROUND INTERFACING */
    .dashboard-metric-workspace {
        flex-grow: 1;
        position: relative;
        display: flex;
        flex-direction: column;
        height: 100%;
    }

    .scrimmed-hero-viewport {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: linear-gradient(to right, #160d08 18%, rgba(22, 13, 8, 0.35)), url('https://images.unsplash.com/photo-1495474472287-4d71bcdd2085?q=80&w=1600&auto=format&fit=crop');
        background-size: cover;
        background-position: center;
        z-index: 1;
    }

    .workspace-interactive-layer {
        position: relative;
        z-index: 5;
        padding: 45px 70px;
        height: 100%;
        display: flex;
        flex-direction: column;
        box-sizing: border-box;
    }

    .top-row-utility-bar {
        display: flex;
        justify-content: flex-end;
        gap: 35px;
        margin-bottom: 75px;
    }

    .hero-typography-block .aesthetic-brand-divider {
        width: 75px;
        height: 4px;
        background-color: #e67e22;
        margin-bottom: 35px;
    }

    .hero-main-title {
        font-size: 4.2rem;
        font-weight: 800;
        line-height: 1.1;
        margin: 0 0 20px 0;
        letter-spacing: -1px;
    }

    .hero-subtext-para {
        font-size: 1.15rem;
        color: #cbd5e0;
        max-width: 520px;
        line-height: 1.6;
        margin-bottom: 25px;
        font-weight: 300;
    }

    .session-termination-link {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        color: #e67e22;
        text-decoration: none;
        font-weight: 700;
        font-size: 0.8rem;
        text-transform: uppercase;
        letter-spacing: 1.5px;
    }

    .session-termination-link:hover {
        color: #ffffff;
    }

    /* CARD GRID SYSTEM ARCHITECTURE */
    .metrics-structural-row-grid {
        margin-top: auto;
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 35px;
        animation: fadeInWorkspace 0.8s ease forwards;
    }

    .metric-card-node {
        background: rgba(255, 255, 255, 0.03);
        border: 1px solid rgba(255, 255, 255, 0.07);
        padding: 30px;
        border-radius: 12px;
        backdrop-filter: blur(12px);
        transition: transform 0.2s ease, border-color 0.2s ease;
    }

    .metric-card-node:hover {
        background: rgba(230, 126, 34, 0.06);
        border-color: rgba(230, 126, 34, 0.25);
        transform: translateY(-6px);
    }

    .metric-label-tag {
        color: #718096;
        font-size: 0.75rem;
        text-transform: uppercase;
        letter-spacing: 2px;
        margin-bottom: 10px;
        font-weight: 700;
    }

    .metric-primary-value {
        font-size: 2.1rem;
        font-weight: 700;
        color: #e67e22;
        margin-bottom: 6px;
    }

    .metric-desc-label {
        font-size: 0.75rem;
        color: #a0aec0;
        opacity: 0.7;
    }

    .status-optimal-green {
        color: #2ecc71 !important;
    }

    @@keyframes fadeInWorkspace {
        from { opacity: 0; transform: translateY(15px); }
        to { opacity: 1; transform: translateY(0); }
    }
</style>