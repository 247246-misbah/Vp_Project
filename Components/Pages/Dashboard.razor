@page "/dashboard"
@inject Misbah_VisualProgramming_Project.Services.HardwareService Hardware
@implements IDisposable

<div class="dashboard-wrapper min-vh-100 p-4">
    <div class="d-flex justify-content-between align-items-center mb-4 pb-3 border-bottom border-secondary border-opacity-10">
        <div>
            <h1 class="fw-bold tracking-tight text-white mb-1 m-0" style="letter-spacing: -0.5px;">
                CAFE COVE <span class="text-gradient-gold">CONTROL HUB</span>
            </h1>
            <p class="text-muted small m-0 uppercase tracking-wider" style="font-size: 0.78rem; letter-spacing: 0.5px;">Digital Twin Telemetry Engine & Hardware Simulation Panel</p>
        </div>
        <div class="live-status-pill d-flex align-items-center gap-2 px-3 py-1.5 rounded-pill glass-card shadow-sm border border-success border-opacity-25">
            <span class="pulse-dot"></span>
            <span class="text-success small fw-bold tracking-wider text-uppercase" style="font-size: 0.7rem;">LIVE ENGINE ACTIVE</span>
        </div>
    </div>

    @if (latestTelemetry == null)
    {
        <div class="d-flex flex-column align-items-center justify-content-center my-5 py-5 rounded-4 glass-card border border-secondary border-opacity-10 shadow">
            <div class="spinner-border text-warning mb-3" style="width: 2.5rem; height: 2.5rem; border-width: 0.22em;" role="status"></div>
            <p class="text-muted tracking-wide small text-uppercase">Establishing Connection to Twin Hardware Module...</p>
        </div>
    }
    else
    {
        <div class="row g-4 mb-4">
            <div class="col-xl-4 col-md-6">
                <div class="telemetry-card h-100 rounded-4 p-4 glass-card border-glow border-glow-blue d-flex flex-column justify-content-between">
                    <div>
                        <div class="d-flex justify-content-between align-items-start mb-3">
                            <span class="text-muted small fw-bold text-uppercase tracking-wider">System Registry</span>
                            <div class="icon-circle bg-blue-dim text-info"><i class="bi bi-cpu-fill"></i></div>
                        </div>
                        <h2 class="fw-bold text-white mb-2 font-monospace fs-3">@latestTelemetry.MachineName</h2>
                    </div>
                    <div class="mt-3">
                        <span class="status-badge badge-blue">
                            <span class="inner-dot bg-info"></span> @latestTelemetry.CurrentState
                        </span>
                    </div>
                </div>
            </div>

            <div class="col-xl-4 col-md-6">
                <div class="telemetry-card h-100 rounded-4 p-4 glass-card border-glow border-glow-red">
                    <div class="d-flex justify-content-between align-items-start mb-2">
                        <span class="text-muted small fw-bold text-uppercase tracking-wider">Core Boiler Temp</span>
                        <div class="icon-circle bg-red-dim text-danger"><i class="bi bi-thermometer-half"></i></div>
                    </div>
                    <div class="d-flex align-items-baseline mb-2">
                        <span class="display-6 fw-bold text-white font-monospace">@latestTelemetry.Temperature.ToString("F2")</span>
                        <span class="text-danger fw-semibold ms-1 fs-5">°C</span>
                    </div>
                    <div class="progress custom-progress bg-dark bg-opacity-50" style="height: 6px;">
                        <div class="progress-bar bg-gradient-danger progress-bar-striped progress-bar-animated" role="progressbar" style="width: @(Math.Min(latestTelemetry.Temperature, 100))%"></div>
                    </div>
                </div>
            </div>

            <div class="col-xl-4 col-md-12">
                <div class="telemetry-card h-100 rounded-4 p-4 glass-card border-glow border-glow-cyan">
                    <div class="d-flex justify-content-between align-items-start mb-2">
                        <span class="text-muted small fw-bold text-uppercase tracking-wider">Water Reservoir</span>
                        <div class="icon-circle bg-cyan-dim text-cyan"><i class="bi bi-droplet-fill"></i></div>
                    </div>
                    <div class="d-flex align-items-baseline mb-2">
                        <span class="display-6 fw-bold text-white font-monospace">@latestTelemetry.WaterLevel</span>
                        <span class="text-cyan fw-semibold ms-1 fs-5">%</span>
                    </div>
                    <div class="progress custom-progress bg-dark bg-opacity-50" style="height: 6px;">
                        <div class="progress-bar bg-gradient-cyan" role="progressbar" style="width: @latestTelemetry.WaterLevel%"></div>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

<style>
    .dashboard-wrapper { background-color: #0b0d11 !important; font-family: 'Segoe UI', sans-serif; }
    .text-gradient-gold { background: linear-gradient(135deg, #ffc107 0%, #ff9800 100%); -webkit-background-clip: text; -webkit-text-fill-color: transparent; }
    .glass-card { background: rgba(22, 26, 35, 0.65) !important; backdrop-filter: blur(12px) !important; border: 1px solid rgba(255, 255, 255, 0.05) !important; }
    .border-glow-blue:hover { border-color: rgba(13, 202, 240, 0.3) !important; }
    .border-glow-red:hover { border-color: rgba(220, 53, 69, 0.3) !important; }
    .border-glow-cyan:hover { border-color: rgba(23, 162, 184, 0.3) !important; }
    .icon-circle { width: 38px; height: 38px; border-radius: 8px; display: flex; align-items: center; justify-content: center; }
    .bg-blue-dim { background-color: rgba(13, 202, 240, 0.08); }
    .bg-red-dim { background-color: rgba(220, 53, 69, 0.08); }
    .bg-cyan-dim { background-color: rgba(23, 162, 184, 0.08); }
    .text-cyan { color: #17a2b8 !important; }
    .bg-gradient-danger { background: linear-gradient(90deg, #dc3545, #ff4757); }
    .bg-gradient-cyan { background: linear-gradient(90deg, #17a2b8, #20c997); }
    .status-badge { padding: 4px 10px; border-radius: 6px; font-size: 0.78rem; display: inline-flex; align-items: center; gap: 6px; }
    .badge-blue { background-color: rgba(13, 202, 240, 0.12); color: #0dcaf0; }
    .inner-dot { width: 6px; height: 6px; border-radius: 50%; }
    .pulse-dot { width: 8px; height: 8px; background-color: #198754; border-radius: 50%; animation: pulseProcessing 1.6s infinite; }
    @@keyframes pulseProcessing { 0% { transform: scale(0.95); } 70% { transform: scale(1); } 100% { transform: scale(0.95); } }
</style>

@code {
    private Misbah_VisualProgramming_Project.Models.HardwareStatus? latestTelemetry;

    protected override async Task OnInitializedAsync()
    {
        latestTelemetry = await Hardware.GetLatestStatus();
        Hardware.OnTelemetryUpdated += HandleTelemetryUpdate;
    }

    private void HandleTelemetryUpdate(Misbah_VisualProgramming_Project.Models.HardwareStatus updatedStatus)
    {
        InvokeAsync(() =>
        {
            latestTelemetry = updatedStatus;
            StateHasChanged();
        });
    }

    public void Dispose()
    {
        Hardware.OnTelemetryUpdated -= HandleTelemetryUpdate;
    }
}