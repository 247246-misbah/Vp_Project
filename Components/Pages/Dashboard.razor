    .feedback-text { font-size: 0.94rem !important; line-height: 1.5 !important; color: #e2e8f0 !important; margin: 0 !important; font-style: italic !important; }
    .light-theme-mode .feedback-text { color: #4a5568 !important; }
    .quote-glyph-open, .quote-glyph-close { color: rgba(230, 126, 34, 0.3) !important; font-size: 1.5rem !important; font-weight: bold !important; line-height: 0 !important; display: inline-block !important; }
    .quote-glyph-open { vertical-align: bottom !important; margin-right: 2px !important; }
    .quote-glyph-close { vertical-align: top !important; margin-left: 2px !important; }
    .empty-reviews-state { grid-column: 1 / -1 !important; text-align: center !important; padding: 50px !important; color: #a0aec0 !important; }
    .empty-glyph { font-size: 3rem !important; display: block !important; margin-bottom: 10px !important; }
</style>