@page "/dashboard"
@using Misbah_VisualProgramming_Project.Models
@using Misbah_VisualProgramming_Project.Services
@inject HardwareService Hardware
@implements IDisposable

<div class="container-fluid p-4 text-white" style="background-color: #0b0d11; min-height: 100vh;">
    <div class="d-flex justify-content-between align-items-center mb-4 pb-3 border-bottom border-secondary border-opacity-20">
        <div>
            <h2 class="text-warning fw-bold m-0">☕ DIGITAL TWIN SIMULATOR CONTROL</h2>
            <p class="text-muted small m-0">Hardware Status Pipeline Intel Telemetry Sync</p>
        </div>
        <div class="badge @(telemetry?.IsConnected == true ? "bg-success" : "bg-danger") px-3 py-2 fs-6">
            @(telemetry?.IsConnected == true ? "● ONLINE" : "○ OFFLINE")
        </div>
    </div>

    @if (telemetry == null)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-warning" role="status"></div>
            <p class="text-muted mt-2">Connecting Hardware Telemetry State...</p>
        </div>
    }
    else
    {
        <div class="row g-4 mb-4">
            <div class="col-md-3">
                <div class="card h-100 text-white" style="background: #161a23; border: 1px solid rgba(255,255,255,0.05); border-radius: 12px;">
                    <div class="card-body">
                        <h6 class="text-muted text-uppercase small font-monospace">Machine Model</h6>
                        <h4 class="text-warning fw-bold mt-2">@telemetry.MachineName</h4>
                        <span class="badge bg-dark border border-secondary text-info mt-2">State: @telemetry.CurrentState</span>
                    </div>
                </div>
            </div>

            <div class="col-md-3">
                <div class="card h-100 text-white" style="background: #161a23; border: 1px solid rgba(255,255,255,0.05); border-radius: 12px;">
                    <div class="card-body">
                        <h6 class="text-muted text-uppercase small font-monospace">Core Temperature</h6>
                        <h3 class="fw-bold text-danger mt-2">@telemetry.Temperature.ToString("F1")°C</h3>
                        <div class="progress mt-3" style="height: 6px; background-color: #2a2f3b;">
                            <div class="progress-bar bg-danger" style="width: @(telemetry.Temperature / 120.0 * 100.0)%"></div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-md-3">
                <div class="card h-100 text-white" style="background: #161a23; border: 1px solid rgba(255,255,255,0.05); border-radius: 12px;">
                    <div class="card-body">
                        <h6 class="text-muted text-uppercase small font-monospace">Water Reservoir Level</h6>
                        <h3 class="fw-bold text-info mt-2">@telemetry.WaterLevel%</h3>
                        <div class="progress mt-3" style="height: 6px; background-color: #2a2f3b;">
                            <div class="progress-bar bg-info" style="width: @telemetry.WaterLevel%"></div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-md-3">
                <div class="card h-100 text-white" style="background: #161a23; border: 1px solid rgba(255,255,255,0.05); border-radius: 12px;">
                    <div class="card-body">
                        <h6 class="text-muted text-uppercase small font-monospace">Espresso Bean Weight</h6>
                        <h3 class="fw-bold text-success mt-2">@telemetry.BeanWeight g</h3>
                        <div class="progress mt-3" style="height: 6px; background-color: #2a2f3b;">
                            <div class="progress-bar bg-success" style="width: @(telemetry.BeanWeight / 500.0 * 100.0)%"></div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

@code {
    private HardwareStatus? telemetry;
    private System.Threading.Timer? _timer;

    protected override async Task OnInitializedAsync()
    {
        // Initial clean data pull from Service
        telemetry = await Hardware.GetLatestStatus();

        // Safe poll timer loop to simulate real-time interactive updates every 3 seconds
        _timer = new System.Threading.Timer(async _ =>
        {
            await InvokeAsync(async () =>
            {
                telemetry = await Hardware.GetLatestStatus();
                StateHasChanged();
            });
        }, null, 3000, 3000);
    }

    public void Dispose()
    {
        _timer?.Dispose();
    }
}