    .workspace-interactive-layer { flex-grow: 1; padding: 10px 70px 60px 70px; display: flex; flex-direction: column; justify-content: center; }
    
    .welcome-hero-block { margin-bottom: 60px; }
    .accent-line-node { width: 60px; height: 4px; background-color: #e67e22; margin-bottom: 25px; }
    .welcome-main-title { font-size: 3.8rem; font-weight: 800; line-height: 1.15; margin: 0 0 20px 0; letter-spacing: -1px; }
    .welcome-subtext { font-size: 1.05rem; color: #cbd5e0; line-height: 1.6; opacity: 0.85; margin: 0; }

    .metrics-cards-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 25px; max-width: 1050px; }
    
    .metric-data-card {
        background: rgba(255, 255, 255, 0.03); border: 1px solid rgba(255, 255, 255, 0.07);
        border-radius: 14px; padding: 30px 25px; backdrop-filter: blur(12px);
        display: flex; flex-direction: column; gap: 8px; box-sizing: border-box;
    }
    
    .clickable-card { cursor: pointer; transition: transform 0.2s, border-color 0.2s, background 0.2s; }
    .clickable-card:hover { transform: translateY(-5px); border-color: #e67e22; background: rgba(230, 126, 34, 0.05); }

    .card-meta-label { font-size: 0.75rem; font-weight: 700; color: #a0aec0; letter-spacing: 1.5px; text-transform: uppercase; }
    .card-numeric-display { font-size: 2.4rem; font-weight: 800; margin: 4px 0; }
    
    .text-amber { color: #e67e22; }
    .text-orange { color: #d35400; }
    .text-emerald { color: #2ecc71; }
    
    .card-context-subtext { font-size: 0.8rem; color: #718096; font-weight: 500; }
</style>