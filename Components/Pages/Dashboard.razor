@page "/dashboard"
@using Misbah_VisualProgramming_Project.Data.Entities
@using Misbah_VisualProgramming_Project.Services
@inject IMenuService MenuService
@inject IOrderService OrderService
@inject ISensorService SensorService

<div class="container-fluid mt-4">
    <div class="p-4 mb-4 bg-dark text-white rounded shadow-sm">
        <h2 class="fw-bold">☕ Cafe Cove Management Dashboard</h2>
        <p class="text-light mb-0">Visual Programming Final Project Web Portal | Air University Kharian Campus</p>
    </div>

    <div class="row mb-4">
        <div class="col-md-12">
            <div class="card border-primary shadow-sm">
                <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
                    <h5 class="mb-0 fw-semibold">⚙️ Digital Twin Hardware Stream</h5>
                    <span class="badge bg-light text-primary fw-bold">Live Telemetry</span>
                </div>
                <div class="card-body bg-light">
                    @if (activeSensor != null)
                    {
                        <div class="row text-center">
                            <div class="col-sm-4 border-end">
                                <small class="text-muted d-block">Appliance Node</small>
                                <strong class="fs-5 text-dark">@activeSensor.MachineName</strong>
                            </div>
                            <div class="col-sm-4 border-end">
                                <small class="text-muted d-block">Core Temp Boiler</small>
                                <strong class="fs-5 text-danger">@activeSensor.Temperature °C</strong>
                            </div>
                            <div class="col-sm-4">
                                <small class="text-muted d-block">Binary Register Math Bitmask</small>
                                <strong class="fs-5 text-success">0x0@activeSensor.StatusBitmask.ToString("X")</strong>
                            </div>
                        </div>
                    }
                    else
                    {
                        <div class="text-center p-2">
                            <div class="spinner-border text-primary spinner-border-sm" role="status"></div>
                            <span class="ms-2 text-muted">Reading physical appliance parameters...</span>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>

    <div class="row g-3 mb-4">
        <div class="col-md-4">
            <div class="card text-white bg-success h-100 shadow-sm">
                <div class="card-body d-flex flex-column justify-content-center">
                    <h6 class="card-title text-uppercase opacity-75">Active Menu Items</h6>
                    <h2 class="display-6 fw-bold">@menuCount</h2>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card text-white bg-info h-100 shadow-sm">
                <div class="card-body d-flex flex-column justify-content-center">
                    <h6 class="card-title text-uppercase opacity-75">Pending Orders</h6>
                    <h2 class="display-6 fw-bold">@orderCount</h2>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card text-white bg-warning h-100 shadow-sm">
                <div class="card-body d-flex flex-column justify-content-center">
                    <h6 class="card-title text-uppercase opacity-75">System Role Context</h6>
                    <h2 class="fs-3 fw-bold">Authorized Session</h2>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-lg-7">
            <div class="card h-100 shadow-sm border-0">
                <div class="card-header bg-white border-bottom py-3">
                    <h5 class="mb-0 fw-bold text-secondary">📋 SQLite Verified Live Menu Inventory</h5>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0 text-center">
                            <thead class="table-light">
                                <tr>
                                    <th>ID</th>
                                    <th>Item Title</th>
                                    <th>Category</th>
                                    <th>Price</th>
                                    <th>Stock Status</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (loadedItems != null && loadedItems.Any())
                                {
                                    @foreach (var item in loadedItems)
                                    {
                                        <tr>
                                            <td><strong>#@item.Id</strong></td>
                                            <td class="text-start text-primary fw-semibold">@item.Name</td>
                                            <td><span class="badge bg-secondary">@item.Category</span></td>
                                            <td class="text-success fw-bold">Rs. @item.Price</td>
                                            <td>
                                                <span class="badge @(item.IsAvailable ? "bg-success-subtle text-success" : "bg-danger-subtle text-danger")">
                                                    @(item.IsAvailable ? $"{item.StockLevel} Units Left" : "Out of stock")
                                                </span>
                                            </td>
                                        </tr>
                                    }
                                }
                                else
                                {
                                    <tr>
                                        <td colspan="5" class="text-muted py-4">No data seed tracks recognized in SQLite tables.</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-5">
            <div class="card h-100 shadow-sm border-0">
                <div class="card-header bg-white border-bottom py-3">
                    <h5 class="mb-0 fw-bold text-secondary">🚀 Direct Project Operations Quick Links</h5>
                </div>
                <div class="card-body">
                    <div class="d-grid gap-3">
                        <a href="/menu/list" class="btn btn-outline-dark p-3 text-start shadow-sm rounded">
                            <h5>📜 Main Menu List Page</h5>
                            <small class="text-muted">Display items cards grid system for walk-in orders</small>
                        </a>
                        <a href="/menu/manage" class="btn btn-outline-primary p-3 text-start shadow-sm rounded">
                            <h5>🛠️ Manage Inventory Panel</h5>
                            <small class="text-muted">Perform complete CRUD adjustments directly on SQL tables</small>
                        </a>
                        <a href="/simulator/digitaltwin" class="btn btn-outline-danger p-3 text-start shadow-sm rounded">
                            <h5>🕹️ Machine Telemetry Simulator</h5>
                            <small class="text-muted">Inspect bitwise state registers and thermal controller grids</small>
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    private List<MenuItem> loadedItems = new();
    private HardwareSensor? activeSensor;
    private int menuCount = 0;
    private int orderCount = 0;

    protected override async Task OnInitializedAsync()
    {
        // Fetching structural lists asynchronously via Dependency Injected repositories
        loadedItems = await MenuService.GetAllMenuItemsAsync();
        menuCount = loadedItems.Count;

        var activeOrders = await OrderService.GetActiveOrdersAsync();
        orderCount = activeOrders.Count;

        activeSensor = await SensorService.GetMachineTelemetryAsync();
    }
}