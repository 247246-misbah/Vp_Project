@page "/dashboard"
@using System.Data
@using MySql.Data.MySqlClient
@inject NavigationManager Navigation
@inject IJSRuntime JSRuntime
@rendermode Microsoft.AspNetCore.Components.Web.RenderMode.InteractiveServer

<div class="dashboard-viewport-container fluid-scroll @(isLightTheme ? "light-theme-mode" : "")">
    
    <aside class="sidebar-brand-panel">
        <div class="brand-container-top">
            <div class="brand-header-node">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-cup-hot-fill" viewBox="0 0 16 16">
                    <path fill-rule="evenodd" d="M.5 6a.5.5 0 0 0-.488.608l1.652 7.434A2.5 2.5 0 0 0 4.104 16h5.792a2.5 2.5 0 0 0 2.44-1.958l.131-.59a3 3 0 0 0 1.3-5.854l.221-.99A.5.5 0 0 0 13.5 6zM13 12.5a2 2 0 0 1-.316-.025l.867-3.898A2.001 2.001 0 0 1 13 12.5"/>
                    <path d="m4.4.8-.003.004-.014.019a4 4 0 0 0-.204.31 2 2 0 0 0-.141.267c-.026.06-.034.092-.037.103v.004a.6.6 0 0 0 .091.248c.075.133.178.272.308.445l.01.012c.118.158.26.347.37.543.112.2.22.455.22.745 0 .188-.065.368-.119.494a3 3 0 0 1-.202.388 5 5 0 0 1-.253.382l-.018.025-.005.008-.002.002A.5.5 0 0 1 3.6 4.2l.003-.004.014-.019a4 4 0 0 0 .204-.31 2 2 0 0 0 .141-.267c.026-.06.034-.092.037-.103a.6.6 0 0 0-.09-.252A4 4 0 0 0 3.6 2.8l-.01-.012a5 5 0 0 1-.37-.543A1.53 1.53 0 0 1 3 1.5c0-.188.065-.368.119-.494.059-.138.134-.274.202-.388a6 6 0 0 1 .253-.382l.025-.035A.5.5 0 0 1 4.4.8m3 0-.003.004-.014.019a4 4 0 0 0-.204.31 2 2 0 0 0-.141.267c-.026.06-.034.092-.037.103v.004a.6.6 0 0 0 .091.248c.075.133.178.272.308.445l.01.012c.118.158.26.347.37.543.112.2.22.455.22.745 0 .188-.065.368-.119.494a3 3 0 0 1-.202.388 5 5 0 0 1-.253.382l-.018.025-.005.008-.002.002A.5.5 0 0 1 6.6 4.2l.003-.004.014-.019a4 4 0 0 0 .204-.31 2 2 0 0 0 .141-.267c.026-.06.034-.092.037-.103a.6.6 0 0 0-.09-.252A4 4 0 0 0 6.6 2.8l-.01-.012a5 5 0 0 1-.37-.543A1.53 1.53 0 0 1 6 1.5c0-.188.065-.368.119-.494.059-.138.134-.274.202-.388a6 6 0 0 1 .253-.382l.025-.035A.5.5 0 0 1 7.4.8m3 0-.003.004-.014.019a4 4 0 0 0-.204.31 2 2 0 0 0-.141.267c-.026.06-.034.092-.037.103v.004a.6.6 0 0 0 .091.248c.075.133.178.272.308.445l.01.012c.118.158.26.347.37.543.112.2.22.455.22.745 0 .188-.065.368-.119.494a3 3 0 0 1-.202.388 5 5 0 0 1-.252.382l-.019.025-.005.008-.002.002A.5.5 0 0 1 9.6 4.2l.003-.004.014-.019a4 4 0 0 0 .204-.31 2 2 0 0 0 .141-.267c.026-.06.034-.092.037-.103a.6.6 0 0 0-.09-.252A4 4 0 0 0 9.6 2.8l-.01-.012a5 5 0 0 1-.37-.543A1.53 1.53 0 0 1 9 1.5c0-.188.065-.368.119-.494.059-.138.134-.274.202-.388a6 6 0 0 1 .253-.382l.025-.035A.5.5 0 0 1 10.4.8"/>
                </svg>
                <h2 class="brand-logo-text">CAFE COVE</h2>
            </div>
            <ul class="navigation-matrix-list">
                <li class="nav-matrix-item @(!showReviews ? "active-state-node" : "")" @onclick="SwitchToHomeView">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-house-door-fill" viewBox="0 0 16 16">
                        <path d="M6.5 14.5v-3.505c0-.245.25-.495.5-.495h2c.25 0 .5.25.5.5v3.5a.5.5 0 0 0 .5.5h4a.5.5 0 0 0 .5-.5v-7a.5.5 0 0 0-.146-.354L13 5.793V2.5a.5.5 0 0 0-.5-.5h-1a.5.5 0 0 0-.5.5v1.293L8.354 1.146a.5.5 0 0 0-.708 0l-6 6A.5.5 0 0 0 1.5 7.5v7a.5.5 0 0 0 .5.5h4a.5.5 0 0 0 .5-.5"/>
                    </svg> Home
                </li>
                <li class="nav-matrix-item" @onclick="NavigateToMenu">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-list" viewBox="0 0 16 16">
                        <path fill-rule="evenodd" d="M2.5 12a.5.5 0 0 1 .5-.5h10a.5.5 0 0 1 0 1H3a.5.5 0 0 1-.5-.5m0-4a.5.5 0 0 1 .5-.5h10a.5.5 0 0 1 0 1H3a.5.5 0 0 1-.5-.5m0-4a.5.5 0 0 1 .5-.5h10a.5.5 0 0 1 0 1H3a.5.5 0 0 1-.5-.5"/>
                    </svg> Menu
                </li>
                <li class="nav-matrix-item" @onclick="NavigateToProfile">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-person-circle" viewBox="0 0 16 16">
                        <path d="M11 6a3 3 0 1 1-6 0 3 3 0 0 1 6 0"/>
                        <path fill-rule="evenodd" d="M0 8a8 8 0 1 1 16 0A8 8 0 0 1 0 8m8-7a7 7 0 0 0-5.468 11.37C3.242 11.226 4.805 10 8 10s4.757 1.225 5.468 2.37A7 7 0 0 0 8 1"/>
                    </svg> Profile
                </li>
                <li class="nav-matrix-item" @onclick="NavigateToPos">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-cart3" viewBox="0 0 16 16">
                        <path d="M0 1.5A.5.5 0 0 1 .5 1H2a.5.5 0 0 1 .485.379L2.89 3H14.5a.5.5 0 0 1 .49.598l-1 5a.5.5 0 0 1-.465.401l-9.397.472L4.415 11H13a.5.5 0 0 1 0 1H4a.5.5 0 0 1-.491-.408L2.01 3.607 1.61 2H.5a.5.5 0 0 1-.5-.5M3.102 4l.84 4.479 9.144-.459L13.89 4zM5 12a2 2 0 1 0 0 4 2 2 0 0 0 0-4m7 0a2 2 0 1 0 0 4 2 2 0 0 0 0-4m-7 1a1 1 0 1 1 0 2 1 1 0 0 1 0-2m7 0a1 1 0 1 1 0 2 1 1 0 0 1 0-2"/>
                    </svg> POS Billing
                </li>
                <li class="nav-matrix-item @(showReviews ? "active-state-node" : "")" @onclick="SwitchToReviewsView">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-chat" viewBox="0 0 16 16">
                        <path d="M2.678 11.894a1 1 0 0 1 .287.801 11 11 0 0 1-.398 2c1.395-.323 2.247-.697 2.634-.893a1 1 0 0 1 .71-.074A8 8 0 0 0 8 14c3.996 0 7-2.807 7-6s-3.004-6-7-6-7 2.808-7 6c0 1.468.617 2.83 1.678 3.894m-.493 3.905a22 22 0 0 1-.713.129c-.2.032-.352-.176-.273-.362a10 10 0 0 0 .244-.637l.003-.01c.248-.72.45-1.548.524-2.319C.743 11.37 0 9.76 0 8c0-3.866 3.582-7 8-7s8 3.134 8 7-3.582 7-8 7a9 9 0 0 1-2.347-.306c-.52.263-1.639.742-3.468 1.105"/>
                    </svg> Reviews
                </li>
            </ul>
        </div>

        <div class="sidebar-quick-settings">
            <div class="settings-separator"></div>
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-ui-radios-grid" viewBox="0 0 16 16">
                <path d="M3.5 15a2.5 2.5 0 1 0 0-5 2.5 2.5 0 0 0 0 5m9-9a2.5 2.5 0 1 0 0-5 2.5 2.5 0 0 0 0 5m0 9a2.5 2.5 0 1 1 0-5 2.5 2.5 0 0 1 0 5M16 3.5a3.5 3.5 0 1 1-7 0 3.5 3.5 0 0 1 7 0m-9 9a3.5 3.5 0 1 1-7 0 3.5 3.5 0 0 1 7 0m5.5 3.5a3.5 3.5 0 1 0 0-7 3.5 3.5 0 0 0 0 7m-9-11a1.5 1.5 0 1 1 0-3 1.5 1.5 0 0 1 0 3m0 2a3.5 3.5 0 1 0 0-7 3.5 3.5 0 0 0 0 7"/>
            </svg>
            
            <div class="settings-row">
                <span class="settings-label">Server Sync</span>
                <span class="status-indicator @(isDbConnected ? "online" : "offline")">
                    <span class="indicator-dot"></span> @(isDbConnected ? "ONLINE" : "OFFLINE")
                </span>
            </div>

            <div class="settings-row">
                <span class="settings-label">Display Mode</span>
                <button type="button" class="accent-toggle-btn" @onclick="ToggleThemeMode">
                    @(isLightTheme ? " DARK THEME" : " LIGHT THEME")
                </button>
            </div>
        </div>
    </aside>

    <main class="dashboard-metric-workspace background-blend-cover">
        
        <div class="top-utility-bar">
            <div class="logout-box-container" @onclick="NavigateToLogin">
                <span class="logout-icon-glyph"></span>
                <span class="logout-text-node">LOGOUT</span>
            </div>
        </div>

        <div class="workspace-interactive-layer fluid-container">
            
            @if (!showReviews)
            {
                <div class="welcome-hero-block">
                    <div class="accent-line-node"></div>
                    <h1 class="welcome-main-title">Welcome Back,<br />@(string.IsNullOrEmpty(Username) ? "Administrator" : Username)!</h1>
                </div>

                <div class="metrics-cards-grid">
                    <div class="metric-data-card clickable-card" @onclick="NavigateToPos">
                        <span class="card-meta-label">ACTIVE ORDERS</span>
                        <div class="card-numeric-display text-amber">@ActiveOrdersCount</div>
                        <span class="card-context-subtext">Currently in queue (Pending) ➜</span>
                    </div>

                    <div class="metric-data-card">
                        <span class="card-meta-label">LIVE REVENUE</span>
                        <div class="card-numeric-display text-orange">Rs. @DailyRevenue.ToString("N0")</div>
                        <span class="card-context-subtext">Total from this session</span>
                    </div>

                    <div class="metric-data-card clickable-card" @onclick="NavigateToMenu">
                        <span class="card-meta-label">TOTAL MENU ITEMS</span>
                        <div class="card-numeric-display text-emerald">@TotalMenuItemsCount</div>
                        <span class="card-context-subtext">Configured recipes in system </span>
                    </div>
                </div>

                <div class="queue-section-container">
                    <h3 class="queue-table-title"><svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-stopwatch" viewBox="0 0 16 16">
                        <path d="M8.5 5.6a.5.5 0 1 0-1 0v2.9h-3a.5.5 0 0 0 0 1H8a.5.5 0 0 0 .5-.5z"/>
                        <path d="M6.5 1A.5.5 0 0 1 7 .5h2a.5.5 0 0 1 0 1v.57c1.36.196 2.594.78 3.584 1.64l.012-.013.354-.354-.354-.353a.5.5 0 0 1 .707-.708l1.414 1.415a.5.5 0 1 1-.707.707l-.353-.354-.354.354-.013.012A7 7 0 1 1 7 2.071V1.5a.5.5 0 0 1-.5-.5M8 3a6 6 0 1 0 .001 12A6 6 0 0 0 8 3"/>
                    </svg> Live Production Order Queue</h3>
                    <div class="menu-table-container">
                        <table class="custom-admin-table">
                            <thead>
                                <tr>
                                    <th>Token ID</th>
                                    <th>Customer Name</th>
                                    <th>Bill Amount</th>
                                    <th>Status</th>
                                    <th style="text-align: center;">Action</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (PendingOrdersList != null && PendingOrdersList.Count > 0)
                                {
                                    @foreach (var order in PendingOrdersList)
                                    {
                                        <tr>
                                            <td class="font-bold-item" style="color: #e67e22;">#00@(order.Id)</td>
                                            <td class="font-bold-item">@order.CustomerName</td>
                                            <td class="price-highlight">Rs. @order.TotalAmount.ToString("N0")</td>
                                            <td><span class="status-badge-pending">@order.Status</span></td>
                                            <td>
                                                <div class="table-action-buttons">
                                                    <button type="button" class="action-complete-btn" @onclick="() => CompleteOrderTransaction(order.Id, order.TotalAmount)">
                                                        ✔ Complete Order
                                                    </button>
                                                </div>
                                            </td>
                                        </tr>
                                    }
                                }
                                else
                                {
                                    <tr>
                                        <td colspan="5" style="text-align: center; color: #a0aec0; padding: 30px; background: #ffffff;">
                                            No active orders in the production queue. All clear!
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            }
            else
            {
                <div class="welcome-hero-block">
                    <div class="accent-line-node"></div>
                    <h1 class="welcome-main-title">Customer Feedback<br />& Inquiries</h1>
                </div>

                <div class="reviews-section-structure">
                    <h3 class="queue-table-title reviews-title"><svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-inbox-fill" viewBox="0 0 16 16">
                        <path d="M4.98 4a.5.5 0 0 0-.39.188L1.54 8H6a.5.5 0 0 1 .5.5 1.5 1.5 0 1 0 3 0A.5.5 0 0 1 10 8h4.46l-3.05-3.812A.5.5 0 0 0 11.02 4zm-1.17-.437A1.5 1.5 0 0 1 4.98 3h6.04a1.5 1.5 0 0 1 1.17.563l3.7 4.625a.5.5 0 0 1 .106.374l-.39 3.124A1.5 1.5 0 0 1 14.117 13H1.883a1.5 1.5 0 0 1-1.489-1.314l-.39-3.124a.5.5 0 0 1 .106-.374z"/>
                    </svg> Message Inbox</h3>
                    
                    <div class="reviews-cards-grid">
                        @if (CustomerQueriesList != null && CustomerQueriesList.Count > 0)
                        {
                            @foreach (var q in CustomerQueriesList)
                            {
                                <div class="feedback-data-card">
                                    <div class="card-meta-block">
                                        <div class="card-avatar-initials">
                                            <span>@(q.Name.Length > 0 ? q.Name[0].ToString().ToUpper() : "?")</span>
                                        </div>
                                        <div class="card-user-details">
                                            <span class="feedback-username">@q.Name</span>
                                            <span class="feedback-email-badge">@q.Email</span>
                                        </div>
                                    </div>
                                    <div class="card-message-body">
                                        <span class="quote-glyph-open">“</span>
                                        <p class="feedback-text">@q.Message</p>
                                        <span class="quote-glyph-close">”</span>
                                    </div>
                                </div>
                            }
                        }
                        else
                        {
                            <div class="empty-reviews-state">
                                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-chat-left-heart" viewBox="0 0 16 16">
                                    <path d="M14 1a1 1 0 0 1 1 1v8a1 1 0 0 1-1 1H4.414A2 2 0 0 0 3 11.586l-2 2V2a1 1 0 0 1 1-1zM2 0a2 2 0 0 0-2 2v12.793a.5.5 0 0 0 .854.353l2.853-2.853A1 1 0 0 1 4.414 12H14a2 2 0 0 0 2-2V2a2 2 0 0 0-2-2z"/>
                                    <path d="M8 3.993c1.664-1.711 5.825 1.283 0 5.132-5.825-3.85-1.664-6.843 0-5.132"/>
                                </svg>
                                <p>No customer reviews or messages found inside database table 'query' yet.</p>
                            </div>
                        }
                    </div>
                </div>
            }

        </div>
    </main>
</div>

@code {
    [Parameter]
    [SupplyParameterFromQuery(Name = "username")]
    public string Username { get; set; } = string.Empty;

    private bool showReviews { get; set; } = false;
    private bool isDbConnected { get; set; } = false;
    private bool isLightTheme { get; set; } = false;

    private int ActiveOrdersCount { get; set; } = 0;
    
    private static decimal DailyRevenue { get; set; } = 0;

    private int TotalMenuItemsCount { get; set; } = 0;
    
    private List<OrderModel> PendingOrdersList = new();
    private List<QueryModel> CustomerQueriesList = new();
    
    private string connString = "Server=localhost;Database=cafe_management;Uid=root;Pwd=;";

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            var savedTheme = await JSRuntime.InvokeAsync<string>("localStorage.getItem", "appThemeMode");
            if (!string.IsNullOrEmpty(savedTheme))
            {
                isLightTheme = (savedTheme == "light");
                StateHasChanged();
            }
        }
    }

    protected override async Task OnInitializedAsync()
    {
        await LoadDashboardMetrics();
    }

    private async Task ToggleThemeMode()
    {
        isLightTheme = !isLightTheme;
        await JSRuntime.InvokeVoidAsync("localStorage.setItem", "appThemeMode", isLightTheme ? "light" : "dark");
    }

    private void NavigateToMenu() => Navigation.NavigateTo("/menu-management");
    private void NavigateToProfile() => Navigation.NavigateTo("/profile");
    private void NavigateToPos() => Navigation.NavigateTo("/pos");
    private void NavigateToLogin() => Navigation.NavigateTo("/login");

    private void SwitchToHomeView() => showReviews = false;

    private async Task SwitchToReviewsView()
    {
        showReviews = true;
        await LoadCustomerQueries();
    }

    private async Task LoadDashboardMetrics()
    {
        PendingOrdersList.Clear();
        try
        {
            using MySqlConnection conn = new(connString);
            await conn.OpenAsync();
            isDbConnected = true;

            string countQuery = "SELECT COUNT(*) FROM orders WHERE status = 'Pending';";
            using (MySqlCommand cmd = new(countQuery, conn))
            {
                ActiveOrdersCount = Convert.ToInt32(await cmd.ExecuteScalarAsync());
            }

            string itemsQuery = "SELECT COUNT(*) FROM menu;";
            using (MySqlCommand cmd = new(itemsQuery, conn))
            {
                TotalMenuItemsCount = Convert.ToInt32(await cmd.ExecuteScalarAsync());
            }

            string queueQuery = "SELECT id, customer_name, total_amount, status FROM orders WHERE status = 'Pending' ORDER BY id ASC;";
            using (MySqlCommand cmd = new(queueQuery, conn))
            {
                using var reader = await cmd.ExecuteReaderAsync();
                while (await reader.ReadAsync())
                {
                    PendingOrdersList.Add(new OrderModel
                    {
                        Id = reader.GetInt32("id"),
                        CustomerName = reader.GetString("customer_name"),
                        TotalAmount = reader.GetDecimal("total_amount"),
                        Status = reader.GetString("status")
                    });
                }
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Database Error: {ex.Message}");
            isDbConnected = false;
            ActiveOrdersCount = 1;
            TotalMenuItemsCount = 12;
            PendingOrdersList.Add(new OrderModel { Id = 8, CustomerName = "Eman Arif", TotalAmount = 830, Status = "Pending" });
        }
    }

    private async Task LoadCustomerQueries()
    {
        CustomerQueriesList.Clear();
        try
        {
            using MySqlConnection conn = new(connString);
            await conn.OpenAsync();

            string selectSql = "SELECT name, email, message FROM query ORDER BY id DESC;";
            using (MySqlCommand cmd = new(selectSql, conn))
            {
                using var reader = await cmd.ExecuteReaderAsync();
                while (await reader.ReadAsync())
                {
                    CustomerQueriesList.Add(new QueryModel
                    {
                        Name = reader.IsDBNull(reader.GetOrdinal("name")) ? "" : reader.GetString("name"),
                        Email = reader.IsDBNull(reader.GetOrdinal("email")) ? "" : reader.GetString("email"),
                        Message = reader.IsDBNull(reader.GetOrdinal("message")) ? "" : reader.GetString("message")
                    });
                }
            }
        }
        catch (Exception)
        {
            CustomerQueriesList.Add(new QueryModel { Name = "Sarah Ahmed", Email = "sarah@gmail.com", Message = "Loved the cozy space!" });
            CustomerQueriesList.Add(new QueryModel { Name = "Zain Malik", Email = "zain@gmail.com", Message = "Excellent customer service and environment." });
        }
    }

    private async Task CompleteOrderTransaction(int orderId, decimal orderAmount)
    {
        try
        {
            using MySqlConnection conn = new(connString);
            await conn.OpenAsync();

            string updateSql = "UPDATE orders SET status = 'Completed' WHERE id = @Id;";
            using (MySqlCommand cmd = new(updateSql, conn))
            {
                cmd.Parameters.AddWithValue("@Id", orderId);
                await cmd.ExecuteNonQueryAsync();
            }

            DailyRevenue += orderAmount;
            await LoadDashboardMetrics();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Transaction Error: {ex.Message}");
        }
    }

    public class OrderModel
    {
        public int Id { get; set; }
        public string CustomerName { get; set; } = string.Empty;
        public decimal TotalAmount { get; set; }
        public string Status { get; set; } = string.Empty;
    }

    public class QueryModel
    {
        public string Name { get; set; } = string.Empty;
        public string Email { get; set; } = string.Empty;
        public string Message { get; set; } = string.Empty;
    }
}

<style>
    /* CSS code with layout warnings permanently resolved */
    .dashboard-viewport-container { width: 100vw; height: 100vh; display: flex; background-color: #160d08; color: #ffffff; font-family: 'Segoe UI', system-ui, sans-serif; margin: 0; padding: 0; overflow: hidden; position: fixed; top: 0; left: 0; z-index: 999; transition: background 0.3s ease, color 0.3s ease; }
    .fluid-scroll { overflow-y: auto; }
    .sidebar-brand-panel { width: 320px; height: 100%; background-color: #120a06; padding: 45px 35px 30px 35px; display: flex; flex-direction: column; border-right: 1px solid rgba(230, 126, 34, 0.12); box-sizing: border-box; justify-content: space-between; }
    .brand-container-top { width: 100%; display: flex; flex-direction: column; }
    .brand-header-node { display: flex; align-items: center; gap: 14px; margin-bottom: 40px; }
    .brand-logo-text { font-size: 1.4rem; font-weight: 800; letter-spacing: 1.5px; margin: 0; color: #ffffff; }
    .navigation-matrix-list { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 6px; }
    .nav-matrix-item { display: flex; align-items: center; gap: 16px; padding: 12px 14px; color: #cbd5e0; font-size: 0.82rem; font-weight: 700; text-transform: uppercase; letter-spacing: 1.5px; cursor: pointer; border-radius: 8px; transition: all 0.2s ease; }
    .nav-matrix-item.active-state-node { color: #e67e22 !important; background: rgba(230, 126, 34, 0.06); }
    .sidebar-quick-settings { display: flex; flex-direction: column; gap: 14px; margin-top: auto; width: 100%; }
    .settings-separator { height: 1px; background: rgba(255, 255, 255, 0.06); width: 100%; margin-bottom: 10px; }
    .settings-row { display: flex; align-items: center; justify-content: space-between; font-size: 0.78rem; font-weight: 600; }
    .settings-label { color: #cbd5e0; }
    .status-indicator { display: flex; align-items: center; gap: 6px; font-size: 0.72rem; font-weight: 700; }
    .indicator-dot { width: 6px; height: 6px; border-radius: 50%; display: inline-block; }
    .status-indicator.online { color: #2ecc71; }
    .status-indicator.online .indicator-dot { background-color: #2ecc71; }
