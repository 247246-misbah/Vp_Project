@page "/"
@page "/dashboard"

<div class="container-fluid py-4" style="background-color: #fdfbf7; min-height: 100vh;">
    <h3 class="fw-bold mb-1">☕ Cafe Cove Control Center</h3>
    <p class="text-muted small mb-4">Hardware Simulation & Digital Twin Monitoring Network</p>

    <div class="row g-4">
        <div class="col-12 col-md-4">
            <div class="card border-0 shadow-sm rounded-4 p-4 bg-white">
                <h6 class="fw-bold text-secondary mb-3">Live Hardware Metrics Telemetry</h6>
                <ul class="list-unstyled mb-0">
                    <li class="mb-3">🌡 Boiler Temperature: <span class="fw-bold text-dark">@HardwareStatus.BoilerTemp°C</span></li>
                    <li class="mb-3">💧 Water Level Status: <span class="fw-bold text-dark">@HardwareStatus.WaterLevel%</span></li>
                    <li>🫘 Beans Hopper Reservoir: <span class="fw-bold text-dark">@HardwareStatus.BeanWeightg / 500g</span></li>
                </ul>
            </div>
        </div>
    </div>
</div>

@code {
    // Synchronized Model Contract Matching System States
    private TwinHardware HardwareStatus { get; set; } = new()
    {
        BoilerTemp = 92.0,
        WaterLevel = 85,
        BeanWeightg = 400 // Exact token matching to completely clean the CS1061 warning pipeline
    };

    public class TwinHardware
    {
        public double BoilerTemp { get; set; }
        public int WaterLevel { get; set; }
        public int BeanWeightg { get; set; }
    }
}