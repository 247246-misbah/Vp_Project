<div class="about-viewport-container">

    <main class="about-content-workspace">
        
        <section class="about-hero-section">
            <div class="hero-overlay">
                <div class="hero-text-center">
                    <p class="hero-top-tag">A SPECIAL COFFEE HOUSE</p>
                    <h1 class="hero-display-title">WHERE COFFEE <br/> MEETS PASSION</h1>
                    <div class="aesthetic-divider"></div>
                </div>
            </div>
        </section>

        <section class="story-layout-grid">
            <div class="story-text-block">
                <h2 class="story-title">STORY ABOUT COFFEE SHOP</h2>
                <div class="story-para">
                    <p><strong>Welcome to Cafe Cove!</strong></p>
                     <p><strong>Where great coffee meets good company.</strong></p>
                    <p>At Cafe Cove, we believe a coffee shop should feel like a pause button in a busy day. We roast our beans in small batches, bake fresh muffins and brownies daily, and serve every cup with the idea that you’re not just grabbing caffeine, you’re taking a moment for yourself.</p>
                </div>
                <button class="btn-learn-more">Learn More</button>
            </div>
            <div class="story-image-block">
                <img src="https://images.unsplash.com/photo-1495474472287-4d71bcdd2085?q=80&w=800&auto=format&fit=crop" alt="Coffee Beans" />
            </div>
        </section>

