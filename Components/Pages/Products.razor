@page "/products"
@inject Misbah_VisualProgramming_Project.Services.CafeService CafeService
@using Misbah_VisualProgramming_Project.Models

<div class="container p-4 text-white" style="background-color: #0b0d11; min-height: 100vh;">
    <div class="mb-4">
        <h2 class="text-warning fw-bold">☕ CAFE PRODUCTS INSTANCE</h2>
        <p class="text-muted small">Live Data Context Synced with MySQL Service Layer</p>
    </div>

    @if (products == null)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-warning" role="status"></div>
            <p class="text-muted mt-2">Loading Cafe Products Menu Context...</p>
        </div>
    }
    else if (!products.Any())
    {
        <div class="alert alert-dark border-secondary text-center text-muted">
            No products available in the database context.
        </div>
    }
    else
    {
        <div class="row g-4">
            @foreach (var product in products)
            {
                <div class="col-md-4">
                    <div class="card h-100 text-white border border-secondary border-opacity-20" style="background: #161a23; border-radius: 12px;">
                        <div class="card-body">
                            <h5 class="card-title text-warning fw-bold">@product.Name</h5>
                            <p class="card-text text-muted mb-1">Category: @product.Category</p>
                            <div class="d-flex justify-content-between align-items-center mt-3">
                                <span class="fs-5 fw-bold text-info">Rs. @product.Price</span>
                                <span class="badge bg-secondary">Stock: @product.Stock</span>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

@code {
    private List<Product>? products;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            // Fixed line to perfectly match CafeService logic
            var allProducts = await CafeService.GetProductsAsync();
            products = allProducts?.ToList() ?? new List<Product>();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Products Render Error: {ex.Message}");
            products = new List<Product>();
        }
    }
}