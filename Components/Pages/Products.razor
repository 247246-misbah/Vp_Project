@page "/products-menu"
@inject Misbah_VisualProgramming_Project.Services.CafeService CafeService
@using Misbah_VisualProgramming_Project.Models

<div class="container-fluid p-4 text-white" style="background-color: #0b0d11; min-vh-100;">
    <div class="d-flex justify-content-between align-items-center mb-4 pb-3 border-bottom border-secondary border-opacity-10">
        <div>
            <h2 class="fw-bold text-warning mb-1 m-0">☕ ESPRESSO MENU SHOWCASE</h2>
            <p class="text-muted small m-0 text-uppercase tracking-wider">Live Inventory Synchronized with MySQL Database Context</p>
        </div>
    </div>

    @if (products == null)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-warning mb-3" role="status"></div>
            <p class="text-muted tracking-wide text-uppercase small">Fetching Espresso Variants from Database...</p>
        </div>
    }
    else if (!products.Any())
    {
        <div class="card text-center p-5 border border-secondary border-opacity-10" style="background: #161a23; border-radius: 16px;">
            <div class="card-body py-5">
                <h3 class="text-muted mb-3">No Menu Items Present in Database Context</h3>
                <p class="text-muted small mb-4">Please verify data inside your XAMPP MySQL database table.</p>
            </div>
        </div>
    }
    else
    {
        <div class="row g-4">
            @foreach (var product in products)
            {
                <div class="col-xl-3 col-lg-4 col-md-6">
                    <div class="card h-100 border border-secondary border-opacity-10 text-white shadow-sm position-relative" style="background: #161a23; border-radius: 16px; overflow: hidden; transition: transform 0.2s;">
                        
                        <span class="position-absolute top-0 end-0 m-3 badge tracking-wide text-uppercase"
                              style="background: @(product.IsAvailable && product.Stock > 0 ? "rgba(25, 135, 84, 0.2)" : "rgba(220, 53, 69, 0.2)");
                            color: @(product.IsAvailable && product.Stock > 0 ? "#25cff2" : "#dc3545");
                            border: 1px solid @(product.IsAvailable && product.Stock > 0 ? "rgba(25, 135, 84, 0.4)" : "rgba(220, 53, 69, 0.4)"); z-index: 10;">
                            @(product.IsAvailable && product.Stock > 0 ? "Available" : "Out of Stock")
                        </span>

                        <div style="height: 200px; background: #0f111a; display: flex; align-items: center; justify-content: center; overflow: hidden;">
                            <img src="@product.ImageUrl" alt="@product.Name" class="w-100 h-100" style="object-fit: cover;" />
                        </div>

                        <div class="card-body d-flex flex-column p-4">
                            <span class="text-muted small fw-bold text-uppercase tracking-wider mb-1">@product.Category</span>
                            <h5 class="card-title fw-bold text-white mb-2 font-monospace">@product.Name</h5>
                            
                            <div class="d-flex justify-content-between align-items-center mt-auto pt-3 border-top border-secondary border-opacity-10">
                                <span class="fs-4 fw-bold font-monospace text-warning">Rs. @product.Price.ToString("F0")</span>
                                <span class="text-muted small">Stock: <strong class="text-white">@product.Stock</strong></span>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

@code {
    private List<Product>? products;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var allProducts = await CafeService.GetProductsAsync();
            products = allProducts?.ToList() ?? new List<Product>();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Menu Core Exception Layer: {ex.Message}");
            products = new List<Product>();
        }
    }
}