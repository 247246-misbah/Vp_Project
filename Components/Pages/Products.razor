@page "/products"
@inject CafeService CafeService
@inject NavigationManager NavManager

<div class="container-fluid py-4" style="background-color: #121212; min-height: 100vh; color: #ffffff; font-family: 'Segoe UI', sans-serif;">
    <div class="d-flex justify-content-between align-items-center mb-4 pb-3 border-bottom border-secondary">
        <div>
            <h2 class="fw-bold text-warning m-0">☕ Espresso Menu Showcase</h2>
            <small class="text-muted">Explore and purchase handcrafted retail blends matching your taste parameters.</small>
        </div>
        <div class="position-relative">
            <button class="btn btn-warning fw-bold d-flex align-items-center gap-2" @onclick="GoToCart">
                🛒 Cart State
                <span class="badge bg-dark text-white rounded-pill">@cartItemsCount</span>
            </button>
        </div>
    </div>

    @if (menuList == null)
    {
        <div class="d-flex justify-content-center align-items-center my-5">
            <div class="spinner-border text-warning" role="status"></div>
            <span class="ms-3 text-warning fs-5">Fetching available items from central repository...</span>
        </div>
    }
    else if (!menuList.Any())
    {
        <div class="alert alert-dark border-secondary text-center p-5 my-4">
            <h4 class="text-warningfw-bold">No Menu Items Present in Database Context</h4>
            <p class="text-muted small">The operational layer requires data seeding inside MySQL. Click below to load demo parameters.</p>
            <button class="btn btn-outline-warning mt-2" @onclick="LoadMockItems">⚡ Inject Demo Evaluation Menu</button>
        </div>
    }
    else
    {
        <div class="row g-4">
            @foreach (var item in menuList)
            {
                <div class="col-md-4 col-sm-6">
                    <div class="card h-100 bg-dark text-white border-secondary shadow card-hover transition-all">
                        <div class="card-body d-flex flex-column justify-content-between p-4">
                            <div>
                                <div class="d-flex justify-content-between align-items-start mb-2">
                                    <h4 class="card-title fw-bold text-warning m-0">@item.Name</h4>
                                    <span class="badge bg-secondary text-uppercase small">@item.Category</span>
                                </div>
                                <p class="card-text text-muted small mb-4" style="line-height: 1.5;">
                                    Premium blend calibrated specifically for internal simulation engines. Secure item profile tracking enabled.
                                </p>
                            </div>
                            
                            <div class="d-flex justify-content-between align-items-center mt-auto pt-3 border-top border-secondary">
                                <span class="fs-4 fw-bold text-success">Rs. @item.Price</span>
                                <button class="btn btn-sm btn-outline-warning px-3 py-2 fw-semibold" @onclick="() => AddItemToCart(item)">
                                    ➕ Add to Order
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

@code {
    private List<Product>? menuList;
    private int cartItemsCount = 0;

    protected override async Task OnInitializedAsync()
    {
        await LoadMenuData();
    }

    private async Task LoadMenuData()
    {
        menuList = await CafeService.GetMenuAsync();
    }

    private void AddItemToCart(Product product)
    {
        cartItemsCount++;
        // State tracking increment logic for active feedback lifecycle mapping
    }

    private void GoToCart()
    {
        // Path pointer redirector
        NavManager.NavigateTo("cart");
    }

    private void LoadMockItems()
    {
        // Simulation data injector context logic if database returns null constraints
        menuList = new List<Product>
        {
            new Product { Id = 1, Name = "Dark Roasted Espresso", Price = 420, Category = "Beverage", IsAvailable = true },
            new Product { Id = 2, Name = "Hazelnut Macchiato", Price = 540, Category = "Beverage", IsAvailable = true },
            new Product { Id = 3, Name = "Caramel Latte Twin", Price = 490, Category = "Beverage", IsAvailable = true },
            new Product { Id = 4, Name = "Fudge Brownie Crunch", Price = 350, Category = "Bakery", IsAvailable = true }
        };
    }
}