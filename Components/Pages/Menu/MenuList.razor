@page "/menu"

<div class="row g-4 fade-in">
    <div class="col-lg-8">
        <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3 mb-4">
            <h3 class="fw-bold m-0 text-dark">Cafe Cove Menu Selection</h3>
            <div class="input-group style-search-bar w-50 max-sm-w-100 shadow-sm rounded-pill overflow-hidden border">
                <span class="input-group-text bg-white border-0 ps-3">🔍</span>
                <input type="text" class="form-control border-0 py-2 ps-1" placeholder="Search beverages or bakery items..." />
            </div>
        </div>

        <div class="d-flex gap-2 mb-4 overflow-auto pb-2">
            <button class="btn btn-dark rounded-pill px-4">All Selection</button>
            <button class="btn btn-outline-secondary border-0 bg-white text-dark rounded-pill px-4 shadow-sm">Hot Coffees</button>
            <button class="btn btn-outline-secondary border-0 bg-white text-dark rounded-pill px-4 shadow-sm">Cold Breathers</button>
            <button class="btn btn-outline-secondary border-0 bg-white text-dark rounded-pill px-4 shadow-sm">Artisan Bakery</button>
        </div>

        <div class="row row-cols-1 row-cols-md-2 g-4">
            <div class="col">
                <div class="cafe-card h-100 border bg-white overflow-hidden d-flex flex-column justify-content-between">
                    <div class="p-4">
                        <div class="d-flex justify-content-between align-items-start">
                            <h5 class="fw-bold text-dark m-0">Irish Velvet Cream Latte</h5>
                            <span class="badge bg-light text-dark border rounded-pill px-3">Espresso</span>
                        </div>
                        <p class="text-muted small mt-2 text-clamp-2">Premium double ristretto shot blended with smooth cream syrup and textured whole milk.</p>
                    </div>
                    <div class="p-4 pt-0 d-flex justify-content-between align-items-center">
                        <span class="fs-5 fw-bold text-dark">Rs. 520</span>
                        <button class="btn btn-dark rounded-pill btn-sm px-3">+ Include in Order</button>
                    </div>
                </div>
            </div>

            <div class="col">
                <div class="cafe-card h-100 border bg-white overflow-hidden d-flex flex-column justify-content-between">
                    <div class="p-4">
                        <div class="d-flex justify-content-between align-items-start">
                            <h5 class="fw-bold text-dark m-0">Almond Butter Croissant</h5>
                            <span class="badge bg-light text-dark border rounded-pill px-3">Bakery</span>
                        </div>
                        <p class="text-muted small mt-2 text-clamp-2">Flaky layers of French pastry filled with sweet almond marzipan paste and toasted shavings.</p>
                    </div>
                    <div class="p-4 pt-0 d-flex justify-content-between align-items-center">
                        <span class="fs-5 fw-bold text-dark">Rs. 380</span>
                        <span class="badge bg-danger text-white rounded-pill px-3 py-1">Out of Stock</span>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="col-lg-4">
        <div class="cafe-card border bg-white p-4 sticky-top shadow-sm" style="top: 90px;">
            <h5 class="fw-bold mb-4 border-bottom pb-2">🛍️ Order Summary</h5>
            
            <div class="cart-scroll-container my-3" style="max-height: 250px; overflow-y: auto;">
                <div class="d-flex justify-content-between align-items-center border-bottom pb-2 mb-2">
                    <div>
                        <h6 class="fw-semibold m-0" style="font-size: 0.9rem;">Irish Velvet Cream Latte</h6>
                        <small class="text-muted">Rs. 520 x 1</small>
                    </div>
                    <div class="d-flex align-items-center gap-2">
                        <button class="btn btn-sm btn-light border p-1 py-0">-</button>
                        <span class="fw-bold px-1">1</span>
                        <button class="btn btn-sm btn-light border p-1 py-0">+</button>
                    </div>
                </div>
            </div>

            <div class="price-breakdown mt-4">
                <div class="d-flex justify-content-between text-muted mb-2 small">
                    <span>Items Subtotal</span>
                    <span>Rs. 520</span>
                </div>
                <div class="d-flex justify-content-between text-muted mb-3 small">
                    <span>General Sales Tax (16%)</span>
                    <span>Rs. 83</span>
                </div>
                <div class="d-flex justify-content-between fs-5 fw-bold border-top pt-3 text-dark">
                    <span>Total Amount:</span>
                    <span class="text-success">Rs. 603</span>
                </div>
            </div>

            <button class="btn btn-dark w-100 py-3 rounded-pill fw-bold mt-4 shadow-sm">
                ⚡ Generate Invoice & Print Bill
            </button>
        </div>
    </div>
</div>