@page "/profile"
@using System.Data
@using MySql.Data.MySqlClient
@rendermode Microsoft.AspNetCore.Components.Web.RenderMode.InteractiveServer

<div class="brown-minimal-viewport">
    <div class="edit-profile-centered-card">
        
        <div class="avatar-top-floating-wrapper">
            <div class="avatar-image-ring">
                <img src="https://images.unsplash.com/photo-1544005313-94ddf0286df2?q=80&w=400&auto=format&fit=crop" class="avatar-profile-img-node" alt="Female Admin Profile" />
                <div class="avatar-edit-action-badge">
                    <span>✏️</span>
                </div>
            </div>
        </div>

        <h1 class="form-display-main-title">Edit Profile</h1>

        @if (!string.IsNullOrEmpty(DatabaseStatusFeedback))
        {
            <div class="execution-feedback-toast-node">
                @if (DatabaseStatusFeedback.Contains("✅"))
                {
                    <span>✅ @DatabaseStatusFeedback.Substring(2)</span>
                }
                else if (DatabaseStatusFeedback.Contains("❌"))
                {
                    <span>❌ @DatabaseStatusFeedback.Substring(2)</span>
                }
                else
                {
                    <span>@DatabaseStatusFeedback</span>
                }
            </div>
        }

        <form class="profile-input-fields-stack" @submit:preventDefault="true">

            <div class="form-group-field-block">
                <label class="form-field-label">Username</label>
                <input type="text" class="profile-stroke-input-element" @bind-value="Username" />
            </div>

            <div class="form-group-field-block">
                <label class="form-field-label">Email</label>
                <input type="email" class="profile-stroke-input-element" @bind-value="UserEmail" />
            </div>

            <div class="form-group-field-block">
                <label class="form-field-label">Phone Number</label>
                <div class="phone-dropdown-input-inline-flex">
                    <div class="phone-prefix-combined-wrapper">
                        <span class="country-prefix-static-tag">+92</span>
                        <span class="dropdown-arrow-indicator-node">▼</span>
                    </div>
                    <input type="text" class="profile-stroke-input-element inline-phone-modifier" placeholder="300 1234567" @bind-value="PhoneNumber" />
                </div>
            </div>

            <div class="form-group-field-block">
                <label class="form-field-label">Password</label>
                <input type="password" class="profile-stroke-input-element" placeholder="••••••••" @bind-value="PasswordHash" />
            </div>

            <div class="form-actions-submission-row-bar">
                <button type="button" class="btn-execution-action-save" @onclick="CommitProfileUpdatesToDatabase">
                    Save Changes
                </button>
                <button type="button" class="btn-execution-action-cancel" @onclick="LoadProfileDataFromDatabase">
                    Cancel
                </button>
            </div>

        </form>

    </div>
</div>

<style>
    /* SOLID MINIMAL CANVAS SYSTEM WITH EXPLICIT CENTERING SYSTEM */
    .brown-minimal-viewport {
        position: fixed;
        top: 0;
        left: 0;
        width: 100vw;
        height: 100vh;
        background: linear-gradient(180deg, #1d0f08 0%, #170a04 100%);
        display: flex;
        justify-content: center;
        align-items: center;
        overflow: hidden;
        padding: 40px;
        box-sizing: border-box;
        z-index: 999999;
        font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
    }

    /* FULLY CENTERED WHITE CARD COMPONENT CONTEXT */
    .edit-profile-centered-card {
        width: 100%;
        max-width: 440px;
        background: #ffffff;
        border-radius: 40px;
        box-shadow: 0 35px 90px rgba(0, 0, 0, 0.45);
        padding: 70px 40px 45px 40px;
        box-sizing: border-box;
        position: relative;
        display: flex;
        flex-direction: column;
        align-items: center;
    }

    /* FULL ROUNDED FLOATING AVATAR IMAGE STRUCT */
    .avatar-top-floating-wrapper {
        display: flex;
        justify-content: center;
        width: 100%;
        position: absolute;
        top: -65px;
        left: 0;
    }

    .avatar-image-ring {
        width: 130px;
        height: 130px;
        border-radius: 50%;
        background: #ffffff;
        padding: 4px;
        box-shadow: 0 12px 28px rgba(0,0,0,0.22);
        position: relative;
    }

    .avatar-profile-img-node {
        width: 100%;
        height: 100%;
        border-radius: 50%;
        object-fit: cover;
        display: block;
    }

    .avatar-edit-action-badge {
        position: absolute;
        bottom: 4px;
        right: 4px;
        width: 32px;
        height: 32px;
        background-color: #1a5ca3;
        border: 2px solid #ffffff;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        font-size: 0.8rem;
        box-shadow: 0 4px 8px rgba(0,0,0,0.15);
    }

    /* CARD CENTRAL EXPLICIT TYPOGRAPHY */
    .form-display-main-title {
        font-size: 2.1rem;
        font-weight: 700;
        color: #000000;
        text-align: center;
        margin: 25px 0 25px 0;
        letter-spacing: -0.5px;
    }

    /* STRUCTURE STACK FIELDS LAYOUT */
    .profile-input-fields-stack {
        display: flex;
        flex-direction: column;
        gap: 18px;
        width: 100%;
    }

    .form-group-field-block {
        display: flex;
        flex-direction: column;
        width: 100%;
        align-items: center;
    }

    .form-field-label {
        font-size: 0.88rem;
        font-weight: 600;
        color: #929196;
        margin-bottom: 6px;
        text-align: center;
        width: 100%;
    }

    /* SOLID DARK OUTLINE ROUNDED INPUT FIELDS */
    .profile-stroke-input-element {
        width: 100%;
        background-color: #ffffff;
        border: 1.8px solid #333333;
        border-radius: 14px;
        padding: 12px 16px;
        font-size: 1rem;
        font-weight: 600;
        color: #000000;
        outline: none;
        box-sizing: border-box;
        transition: border-color 0.2s ease;
        text-align: center;
    }

        .profile-stroke-input-element:focus {
            border-color: #1a5ca3;
        }

    /* FIXED SYMMETRIC PHONE FIELD CONTAINER LAYOUT */
    .phone-dropdown-input-inline-flex {
        display: block;
        position: relative;
        width: 100%;
        box-sizing: border-box;
    }

    .phone-prefix-combined-wrapper {
        position: absolute;
        display: flex;
        align-items: center;
        height: 48px;
        padding-left: 20px;
        user-select: none;
        pointer-events: none;
        z-index: 5;
    }

    .country-prefix-static-tag {
        font-size: 1rem;
        font-weight: 600;
        color: #333333;
        margin-right: 5px;
    }

    .dropdown-arrow-indicator-node {
        font-size: 0.6rem;
        color: #777777;
    }

    .inline-phone-modifier {
        padding-left: 70px !important;
        padding-right: 70px !important;
        text-align: center !important;
        letter-spacing: 0.5px;
    }

    /* ACTION ALIGNMENT MATRIX PANEL HOUSING FOOTERS BUTTON */
    .form-actions-submission-row-bar {
        display: flex;
        flex-direction: column;
        gap: 12px;
        margin-top: 15px;
        width: 100%;
    }

    .btn-execution-action-save {
        width: 100%;
        background-color: #5d2f13;
        color: #ffffff;
        border: none;
        border-radius: 14px;
        padding: 15px;
        font-size: 1rem;
        font-weight: 700;
        cursor: pointer;
        transition: background-color 0.2s ease, transform 0.2s ease;
    }

        .btn-execution-action-save:hover {
            background-color: #46220d;
            transform: translateY(-1px);
        }

    .btn-execution-action-cancel {
        width: 100%;
        background-color: #f5f5f7;
        color: #555555;
        border: 1px solid #dddddd;
        border-radius: 14px;
        padding: 12px;
        font-size: 0.98rem;
        font-weight: 600;
        cursor: pointer;
        transition: background-color 0.2s ease;
    }

        .btn-execution-action-cancel:hover {
            background-color: #eaeaea;
        }

    .execution-feedback-toast-node {
        background-color: #f0f7f4;
        border: 1px solid #d2e7de;
        color: #1e6b43;
        padding: 12px;
        border-radius: 12px;
        font-size: 0.88rem;
        font-weight: 600;
        text-align: center;
        margin-bottom: 15px;
        width: 100%;
        box-sizing: border-box;
    }
</style>

@code {
    private string Username { get; set; } = string.Empty;
    private string UserEmail { get; set; } = string.Empty;
    private string PhoneNumber { get; set; } = string.Empty;
    private string PasswordHash { get; set; } = string.Empty; // Added Password string variable

    private string DatabaseStatusFeedback { get; set; } = string.Empty;
    private string connString = "Server=localhost;Database=cafe_management;Uid=root;Pwd=;";

    protected override async Task OnInitializedAsync()
    {
        await LoadProfileDataFromDatabase();
    }

    private async Task LoadProfileDataFromDatabase()
    {
        Username = string.Empty;
        UserEmail = string.Empty;
        PhoneNumber = string.Empty;
        PasswordHash = string.Empty;

        try
        {
            using (MySqlConnection connection = new MySqlConnection(connString))
            {
                await connection.OpenAsync();
                
                // Query incorporates fetching PasswordHash column data directly
                string selectQuery = "SELECT Username, Email, PhoneNumber, PasswordHash FROM Users WHERE Role = 'Admin' LIMIT 1;";
                
                using (MySqlCommand cmd = new MySqlCommand(selectQuery, connection))
                {
                    using (MySqlDataReader reader = (MySqlDataReader)await cmd.ExecuteReaderAsync())
                    {
                        if (await reader.ReadAsync())
                        {
                            Username = reader["Username"]?.ToString() ?? "@sabrina";
                            UserEmail = reader["Email"]?.ToString() ?? "sabrina@cafe.com";
                            PhoneNumber = reader["PhoneNumber"]?.ToString() ?? "";
                            PasswordHash = reader["PasswordHash"]?.ToString() ?? "";
                            DatabaseStatusFeedback = "✅ Profile loaded from database.";
                        }
                        else
                        {
                            DatabaseStatusFeedback = "⚠️ No existing Admin record found. Enter details and click Save Changes.";
                        }
                    }
                }
            }
        }
        catch (Exception ex)
        {
            DatabaseStatusFeedback = $"❌ System Error Loading Profile: {ex.Message}";
        }
    }

    private async Task CommitProfileUpdatesToDatabase()
    {
        try
        {
            DatabaseStatusFeedback = "🔄 Synchronizing data with Database server...";
            await Task.Delay(200);

            using (MySqlConnection connection = new MySqlConnection(connString))
            {
                await connection.OpenAsync();

                // Update incorporates updating PasswordHash data block
                string query = @"
                    UPDATE Users 
                    SET Email = @Email, 
                        Username = @Username,
                        PhoneNumber = @PhoneNo,
                        PasswordHash = @PasswordHash
                    WHERE Role = 'Admin' 
                    LIMIT 1;";

                using (MySqlCommand cmd = new MySqlCommand(query, connection))
                {
                    cmd.Parameters.AddWithValue("@Username", Username);
                    cmd.Parameters.AddWithValue("@Email", UserEmail);
                    cmd.Parameters.AddWithValue("@PhoneNo", PhoneNumber);
                    cmd.Parameters.AddWithValue("@PasswordHash", PasswordHash);

                    int rowsAffected = await cmd.ExecuteNonQueryAsync();

                    if (rowsAffected > 0)
                    {
                        DatabaseStatusFeedback = "✅ Profile changes committed to 'cafe_management' database successfully!";
                    }
                    else
                    {
                        string insertQuery = @"
                            INSERT INTO Users (Username, Email, PhoneNumber, PasswordHash, Role) 
                            VALUES (@Username, @Email, @PhoneNo, @PasswordHash, 'Admin');";
                        
                        using (MySqlCommand insertCmd = new MySqlCommand(insertQuery, connection))
                        {
                            insertCmd.Parameters.AddWithValue("@Username", Username);
                            insertCmd.Parameters.AddWithValue("@Email", UserEmail);
                            insertCmd.Parameters.AddWithValue("@PhoneNo", PhoneNumber);
                            insertCmd.Parameters.AddWithValue("@PasswordHash", PasswordHash);
                            await insertCmd.ExecuteNonQueryAsync();
                        }
                        DatabaseStatusFeedback = "✅ New Admin profile initialized in Database!";
                    }
                }
            }
        }
        catch (Exception ex)
        {
            DatabaseStatusFeedback = $"❌ Critical System Error: {ex.Message}";
        }
    }
}