                    <h1 class="hero-display-title">WE WOULD LOVE <br/> TO HEAR FROM YOU</h1>
                    <div class="aesthetic-divider"></div>
                </div>
            </div>
        </section>

        <section class="contact-layout-grid">
            
            <div class="contact-card-form-wrapper">
                <div class="form-header-row">
                    <h2 class="form-main-title">GET IN TOUCH</h2>
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-chat-square-heart" viewBox="0 0 16 16">
  <path d="M14 1a1 1 0 0 1 1 1v8a1 1 0 0 1-1 1h-2.5a2 2 0 0 0-1.6.8L8 14.333 6.1 11.8a2 2 0 0 0-1.6-.8H2a1 1 0 0 1-1-1V2a1 1 0 0 1 1-1zM2 0a2 2 0 0 0-2 2v8a2 2 0 0 0 2 2h2.5a1 1 0 0 1 .8.4l1.9 2.533a1 1 0 0 0 1.6 0l1.9-2.533a1 1 0 0 1 .8-.4H14a2 2 0 0 0 2-2V2a2 2 0 0 0-2-2z"/>
  <path d="M8 3.993c1.664-1.711 5.825 1.283 0 5.132-5.825-3.85-1.664-6.843 0-5.132"/>
</svg>
                </div>

                @if (!string.IsNullOrEmpty(SubmissionFeedback))
                {
                    <div class="submission-feedback-toast">
                        @SubmissionFeedback
                    </div>
                }

                <form class="interactive-input-form" @submit:preventDefault="true">
                    <div class="input-field-node">
                        <input type="text" placeholder="Your Name" class="custom-form-control" @bind-value="FormName" required />
                    </div>
                    <div class="input-field-node">
                        <input type="email" placeholder="Your Email" class="custom-form-control" @bind-value="FormEmail" required />
                    </div>
                    <div class="input-field-node">
                        <input type="text" placeholder="Subject" class="custom-form-control" @bind-value="FormSubject" required />
                    </div>
                    <div class="input-field-node">
                        <textarea placeholder="Message" rows="5" class="custom-form-control location-textarea" @bind="FormMessage" required></textarea>
                    </div>
                    <button type="submit" class="btn-send-message" @onclick="SubmitQueryToDatabase">Send Message</button>
                </form>
            </div>

            <div class="contact-meta-details-wrapper">
                <h3 class="details-section-title">Contact Details</h3>
                
                <div class="meta-info-strip-grid">
