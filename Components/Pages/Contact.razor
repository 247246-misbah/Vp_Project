@page "/contact"
@using System.Data
@using MySql.Data.MySqlClient
@inject NavigationManager Navigation
@rendermode Microsoft.AspNetCore.Components.Web.RenderMode.InteractiveServer

<header class="top-glass-navbar">
    <div class="nav-brand-side" @onclick='() => NavTo("/login")' style="cursor: pointer;">
        <span class="nav-brand-icon">☕</span>
        <span class="nav-brand-text">CAFE COVE</span>
    </div>
    
    <nav class="nav-links-side">
        <button class="portal-nav-link" @onclick='() => NavTo("/about")'>About Us</button>
        <button class="portal-nav-link active-panel-flag">Contact</button>
    </nav>
</header>

<div class="contact-viewport-container">

    <main class="contact-content-workspace">
        
        <section class="contact-hero-section">
            <div class="hero-overlay">
                <div class="hero-text-center">
                    <p class="hero-top-tag">SAY HELLO TO US</p>
                    <h1 class="hero-display-title">WE WOULD LOVE <br/> TO HEAR FROM YOU</h1>
                    <div class="aesthetic-divider"></div>
                </div>
            </div>
        </section>

        <section class="contact-layout-grid">
            
            <div class="contact-card-form-wrapper">
                <div class="form-header-row">
                    <h2 class="form-main-title">GET IN TOUCH</h2>
                    <div class="coffee-bag-icon">🤎</div>
                </div>

                @if (!string.IsNullOrEmpty(SubmissionFeedback))
                {
                    <div class="submission-feedback-toast">
                        @SubmissionFeedback
                    </div>
                }

                <form class="interactive-input-form" @submit:preventDefault="true">
                    <div class="input-field-node">
                        <input type="text" placeholder="Your Name" class="custom-form-control" @bind-value="FormName" required />
                    </div>
                    <div class="input-field-node">
                        <input type="email" placeholder="Your Email" class="custom-form-control" @bind-value="FormEmail" required />
                    </div>
                    <div class="input-field-node">
                        <input type="text" placeholder="Subject" class="custom-form-control" @bind-value="FormSubject" required />
                    </div>
                    <div class="input-field-node">
                        <textarea placeholder="Message" rows="5" class="custom-form-control location-textarea" @bind="FormMessage" required></textarea>
                    </div>
                    <button type="submit" class="btn-send-message" @onclick="SubmitQueryToDatabase">Send Message</button>
                </form>
            </div>

            <div class="contact-meta-details-wrapper">
                <h3 class="details-section-title">Contact Details</h3>
                
                <div class="meta-info-strip-grid">
                    <div class="info-strip-item">
                        <span class="strip-icon-node">📍</span>
                        <div class="strip-text-block">
                            <p class="info-line-text header-title">Air University Kharian Campus</p>
                            <p class="info-line-text sub-description">Misbah Visual Programming Project Node</p>
                        </div>
                    </div>

                    <div class="info-strip-item">
                        <span class="strip-icon-node">✉️</span>
                        <div class="strip-text-block">
                            <p class="info-line-text">contact@@cafecove.au</p>
                        </div>
                    </div>

                    <div class="info-strip-item">
                        <span class="strip-icon-node">📞</span>
                        <div class="strip-text-block">
                            <p class="info-line-text">+92 123 4567890</p>
                        </div>
                    </div>
                </div>

                <div class="map-embed-mock-container">
                    <div class="map-action-tabs-bar">
                        <button class="map-tab-btn active-map-tab">Map</button>
                        <button class="map-tab-btn">Satellite</button>
                    </div>
                    <div class="map-render-canvas-area">
                        <div class="map-pin-indicator">
                            <span class="pin-marker-glyph">📍</span>
                            <div class="pin-tooltip-box">
                                <strong>Air University</strong><br/>Kharian Campus
                            </div>
                        </div>
                        <div class="map-controls-mock">
                            <button class="zoom-mock-btn">+</button>
                            <button class="zoom-mock-btn">-</button>
                        </div>
                    </div>
                </div>

            </div>
        </section>

    </main>
</div>

@code {
    private string FormName { get; set; } = string.Empty;
    private string FormEmail { get; set; } = string.Empty;
    private string FormSubject { get; set; } = string.Empty;
    private string FormMessage { get; set; } = string.Empty;

    private string SubmissionFeedback { get; set; } = string.Empty;

    private string connString = "Server=localhost;Database=cafe_management;Uid=root;Pwd=;";

    private void NavTo(string url) => Navigation.NavigateTo(url);

    private async Task SubmitQueryToDatabase()
    {
        if (string.IsNullOrWhiteSpace(FormName) || 
            string.IsNullOrWhiteSpace(FormEmail) || 
            string.IsNullOrWhiteSpace(FormSubject) || 
            string.IsNullOrWhiteSpace(FormMessage))
        {
            SubmissionFeedback = "⚠️ Please fill in all fields before sending.";
            return;
        }

        try
        {
            using (MySqlConnection connection = new MySqlConnection(connString))
            {
                await connection.OpenAsync();

                string insertQuery = @"
                    INSERT INTO Query (name, email, subject, message) 
                    VALUES (@Name, @Email, @Subject, @Message);";

                using (MySqlCommand cmd = new MySqlCommand(insertQuery, connection))
                {
                    cmd.Parameters.AddWithValue("@Name", FormName);
                    cmd.Parameters.AddWithValue("@Email", FormEmail);
                    cmd.Parameters.AddWithValue("@Subject", FormSubject);
                    cmd.Parameters.AddWithValue("@Message", FormMessage);

                    await cmd.ExecuteNonQueryAsync();
                }
            }

            SubmissionFeedback = "✅ Message sent successfully!";

            FormName = string.Empty;
            FormEmail = string.Empty;
            FormSubject = string.Empty;
            FormMessage = string.Empty;
        }
        catch (Exception ex)
        {
            SubmissionFeedback = $"❌ Error writing query to database: {ex.Message}";
        }
    }
}

<style>
