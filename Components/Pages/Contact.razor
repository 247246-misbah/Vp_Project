@page "/contact"
@using Microsoft.AspNetCore.Authorization
@attribute [AllowAnonymous]
@inject NavigationManager Navigation
@rendermode Microsoft.AspNetCore.Components.Web.RenderMode.InteractiveServer

<header class="top-glass-navbar">
    <div class="nav-brand-side" @onclick='() => NavTo("/login")' style="cursor: pointer;">
        <span class="nav-brand-icon">☕</span>
        <span class="nav-brand-text">CAFE COVE</span>
    </div>
    
    <nav class="nav-links-side">
        <button class="portal-nav-link" @onclick='() => Navigation.NavigateTo("/about")'>About Us</button>
        <button class="portal-nav-link" @onclick='() => Navigation.NavigateTo("/gallery")'>Gallery</button>
        <a href="javascript:void(0)" class="portal-nav-link">Support</a>
        <button class="portal-nav-link active-panel-flag">Contact</button>
    </nav>
</header>

<div class="contact-viewport-container">
    
    <main class="contact-main-layout">
        <div class="contact-grid-wrapper">
            
            <div class="contact-card-panel">
                <div class="form-header-node">
                    <h2 class="form-title">GET IN TOUCH</h2>
                    <span class="form-header-icon">🫘</span>
                </div>

                <form @submit:preventDefault>
                    <div class="mb-3-custom">
                        <input type="text" class="form-field-node" placeholder="Your Name" required />
                    </div>

                    <div class="mb-3-custom">
                        <input type="email" class="form-field-node" placeholder="Your Email" required />
                    </div>

                    <div class="mb-3-custom">
                        <input type="text" class="form-field-node" placeholder="Subject" required />
                    </div>

                    <div class="mb-4-custom">
                        <textarea class="form-field-node field-textarea" placeholder="Message" required></textarea>
                    </div>

                    <button type="submit" class="btn-send-message">
                        <span>Send Message</span>
                    </button>
                </form>
            </div>

            <div class="details-card-panel">
                <h3 class="details-section-title">Contact Details</h3>
                
                <div class="info-matrix-rows">
                    <div class="info-node-item">
                        <span class="info-icon-pin">📍</span>
                        <div class="info-text-block">
                            <p class="m-0 fw-bold-node">Air University Kharian Campus</p>
                            <p class="m-0 text-muted-node">Misbah Visual Programming Project Node</p>
                        </div>
                    </div>

                    <div class="info-node-item">
                        <span class="info-icon-pin">✉️</span>
                        <div class="info-text-block">
                            <p class="m-0 text-link-node">contact@cafecove.au</p>
                        </div>
                    </div>

                    <div class="info-node-item">
                        <span class="info-icon-pin">📞</span>
                        <div class="info-text-block">
                            <p class="m-0 text-link-node">+92 123 4567890</p>
                        </div>
                    </div>
                </div>

                <div class="map-embed-container shadow-sm">
                    <div class="map-control-header">
                        <button class="map-mode-btn active">Map</button>
                        <button class="map-mode-btn">Satellite</button>
                    </div>
                    <div class="map-canvas-mock">
                        <div class="map-marker-pin">📍</div>
                        <div class="map-popup-badge">
                            <strong>Air University Kharian Campus</strong>
                            <span>Misbah Visual Prog...</span>
                        </div>
                    </div>
                </div>
            </div>

        </div>
    </main>
</div>

@code {
    private void NavTo(string url) => Navigation.NavigateTo(url);
}

<style>
    .top-glass-navbar {
        position: fixed;
        top: 0; left: 0; width: 100vw; height: 70px;
        background: rgba(18, 10, 6, 0.6);
        backdrop-filter: blur(15px); -webkit-backdrop-filter: blur(15px);
        border-bottom: 1px solid rgba(255, 255, 255, 0.08);
        display: flex; justify-content: space-between; align-items: center;
        padding: 0 50px; box-sizing: border-box; z-index: 10000;
    }

    .nav-brand-side { display: flex; align-items: center; gap: 10px; }
    .nav-brand-text { color: #ffffff; font-weight: 800; letter-spacing: 1.5px; font-size: 1.2rem; }
    .nav-links-side { display: flex; align-items: center; gap: 35px; }

    .portal-nav-link {
        background: none; border: none; color: #ffffff;
        font-size: 0.85rem; text-transform: uppercase; letter-spacing: 1.5px;
        font-weight: 600; opacity: 0.75; cursor: pointer;
    }

    .portal-nav-link:hover, .portal-nav-link.active-panel-flag { opacity: 1; color: #e67e22; }

    .contact-viewport-container {
        width: 100vw; height: 100vh; background-color: #160d08; color: #ffffff;
        position: fixed; top: 0; left: 0; padding-top: 70px; box-sizing: border-box;
    }

    .contact-main-layout { width: 100%; height: 100%; display: flex; align-items: center; justify-content: center; padding: 40px; box-sizing: border-box; }
    .contact-grid-wrapper { display: grid; grid-template-columns: 1fr 1fr; gap: 50px; width: 100%; max-width: 1100px; }
    .contact-card-panel, .details-card-panel { background: rgba(26, 17, 10, 0.6); border: 1px solid rgba(255, 255, 255, 0.05); border-radius: 14px; padding: 40px; }
    
    .form-header-node { display: flex; justify-content: space-between; align-items: center; margin-bottom: 30px; border-bottom: 1px solid rgba(255,255,255,0.05); padding-bottom: 15px; }
    .form-title { font-size: 1.8rem; font-weight: 800; margin: 0; }
    
    .mb-3-custom { margin-bottom: 20px; }
    .mb-4-custom { margin-bottom: 25px; }

    .form-field-node {
        width: 100%; background: rgba(255, 255, 255, 0.04); border: 1px solid rgba(255, 255, 255, 0.1);
        border-radius: 8px; padding: 14px 18px; color: #ffffff; font-size: 0.95rem; outline: none; box-sizing: border-box;
    }

    .form-field-node:focus { border-color: #e67e22; box-shadow: 0 0 0 3px rgba(230, 126, 34, 0.15); }
    .field-textarea { height: 120px; resize: none; }

    .btn-send-message { background: #e67e22; color: white; border: none; width: 100%; padding: 15px; border-radius: 8px; font-weight: 700; cursor: pointer; }
    .details-section-title { font-size: 1.5rem; font-weight: 700; margin: 0 0 30px 0; color: #e67e22; }
    .info-matrix-rows { display: flex; flex-direction: column; gap: 25px; margin-bottom: 35px; }
    .info-node-item { display: flex; align-items: flex-start; gap: 20px; }
    .fw-bold-node { font-weight: 600; }
    .text-muted-node { color: rgba(255,255,255,0.6); font-size: 0.9rem; }

    .map-embed-container { width